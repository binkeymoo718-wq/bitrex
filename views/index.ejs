<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BITREX | Wealth Evolution</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #635BFF;
            --success: #00FFC2;
            --bg: #F8FAFC;
            --card-bg: #FFFFFF;
            --text: #1E293B;
            --text-light: #64748B;
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--bg); 
            color: var(--text); 
            margin: 0; 
            padding-bottom: 90px; 
        }

        .header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            padding: 20px;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid #E2E8F0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .balance-card {
            background: linear-gradient(135deg, var(--primary), #4F46E5);
            color: white;
            margin: 20px;
            padding: 30px;
            border-radius: 24px;
            box-shadow: 0 10px 25px rgba(99, 91, 255, 0.3);
        }

        .balance-amount { font-size: 2.2rem; font-weight: 700; margin: 0; }

        .section-title { padding: 0 20px; font-weight: 700; margin-top: 20px; }
        
        .city-scroll {
            display: flex;
            overflow-x: auto;
            padding: 10px 20px;
            gap: 15px;
            scrollbar-width: none;
        }
        .city-scroll::-webkit-scrollbar { display: none; }

        .city-card {
            min-width: 180px;
            background: var(--card-bg);
            padding: 20px;
            border-radius: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border: 1px solid #F1F5F9;
            text-align: center;
        }

        .city-profit { 
            color: #059669; 
            font-weight: 700; 
            background: #00ffc215; 
            padding: 4px 8px; 
            border-radius: 6px; 
            font-size: 0.85rem;
            display: inline-block;
            margin: 10px 0;
        }

        .btn-primary { 
            background: var(--primary); 
            color: white; 
            border: none; 
            padding: 12px; 
            border-radius: 12px; 
            font-weight: 600; 
            width: 100%; 
            cursor: pointer;
        }

        .bottom-nav {
            position: fixed;
            bottom: 0;
            width: 100%;
            background: white;
            display: flex;
            justify-content: space-around;
            padding: 12px 0;
            border-top: 1px solid #E2E8F0;
            box-shadow: 0 -5px 15px rgba(0,0,0,0.03);
        }

        .nav-item { text-align: center; font-size: 0.75rem; color: var(--text-light); cursor: pointer; }
        .nav-item.active { color: var(--primary); font-weight: 700; }
        .nav-icon { font-size: 1.4rem; display: block; margin-bottom: 2px; }

        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); }
        .modal-content { background: white; margin: 20% auto; padding: 25px; border-radius: 24px; width: 85%; max-width: 350px; }
        
        input, textarea { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #E2E8F0; border-radius: 12px; box-sizing: border-box; }
    </style>
</head>
<body>

    <div class="header">
        <span style="font-weight: 800; color: var(--primary); letter-spacing: -1px;">BITREX</span>
        <div style="background: #f1f5f9; padding: 5px 12px; border-radius: 100px; font-size: 0.8rem; font-weight: 600;">
            📍 <%= user.active_city || 'No City' %>
        </div>
    </div>

    <div class="balance-card">
        <div style="opacity: 0.9; font-size: 0.9rem;">Available Balance</div>
        <h2 class="balance-amount">Ksh <%= user.balance %></h2>
        <div style="margin-top: 20px; display: flex; gap: 10px;">
            <button onclick="showModal('depositModal')" style="flex:1; background: rgba(255,255,255,0.2); border:none; color:white; padding:12px; border-radius:12px; font-weight:600;">Deposit</button>
            <button onclick="showModal('withdrawModal')" style="flex:1; background: rgba(255,255,255,0.2); border:none; color:white; padding:12px; border-radius:12px; font-weight:600;">Withdraw</button>
        </div>
    </div>

    <h3 class="section-title">City Investment Tiers</h3>
    <div class="city-scroll">
        <div class="city-card">
            <div style="font-weight:700;">CITY A</div>
            <div class="city-profit">+ Ksh 50/day</div>
            <p style="font-size: 0.8rem; color: var(--text-light); margin: 5px 0;">Cost: Ksh 1,500</p>
            <button class="btn-primary" onclick="invest('CITY A', 1500)">Invest</button>
        </div>
        <div class="city-card">
            <div style="font-weight:700;">CITY B</div>
            <div class="city-profit">+ Ksh 100/day</div>
            <p style="font-size: 0.8rem; color: var(--text-light); margin: 5px 0;">Cost: Ksh 3,200</p>
            <button class="btn-primary" onclick="invest('CITY B', 3200)">Invest</button>
        </div>
        <div class="city-card">
            <div style="font-weight:700;">CITY C</div>
            <div class="city-profit">+ Ksh 200/day</div>
            <p style="font-size: 0.8rem; color: var(--text-light); margin: 5px 0;">Cost: Ksh 7,200</p>
            <button class="btn-primary" onclick="invest('CITY C', 7200)">Invest</button>
        </div>
        <div class="city-card">
            <div style="font-weight:700;">CITY D</div>
            <div class="city-profit">+ Ksh 400/day</div>
            <p style="font-size: 0.8rem; color: var(--text-light); margin: 5px 0;">Cost: Ksh 15,000</p>
            <button class="btn-primary" onclick="invest('CITY D', 15000)">Invest</button>
        </div>
    </div>

    <nav class="bottom-nav">
        <div class="nav-item active" onclick="location.reload()">
            <span class="nav-icon">🏠</span>Home
        </div>
        <div class="nav-item" onclick="claimTask()">
            <span class="nav-icon">⚡</span>Task
        </div>
        <div class="nav-item" onclick="showModal('withdrawModal')">
            <span class="nav-icon">💳</span>Wallet
        </div>
    </nav>

    <div id="depositModal" class="modal">
        <div class="modal-content">
            <h3>Deposit Ksh</h3>
            <p style="font-size: 0.85rem; color: var(--text-light);">Pay to M-PESA: <strong>0733319700</strong></p>
            <input type="number" id="dep-amount" placeholder="Amount (Min 300)">
            <textarea id="dep-evidence" rows="3" placeholder="Paste MPESA Confirmation Message Here..."></textarea>
            <button class="btn-primary" onclick="submitDeposit()">Submit Deposit</button>
            <button onclick="closeModal('depositModal')" style="width:100%; border:none; background:none; margin-top:15px; color: var(--text-light);">Cancel</button>
        </div>
    </div>

    <div id="withdrawModal" class="modal">
        <div class="modal-content">
            <h3>Withdraw</h3>
            <input type="number" id="wit-amount" placeholder="Amount (Min 500)">
            <button class="btn-primary" onclick="submitWithdraw()">Request Withdrawal</button>
            <button onclick="closeModal('withdrawModal')" style="width:100%; border:none; background:none; margin-top:15px; color: var(--text-light);">Cancel</button>
        </div>
    </div>

    <script>
        function showModal(id) { document.getElementById(id).style.display = 'block'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        async function claimTask() {
            const res = await fetch('/claim_task', { method: 'POST' });
            const data = await res.json();
            alert(data.message);
            if (data.success) location.reload();
        }

        async function invest(city, cost) {
            if(!confirm(`Invest in ${city} for Ksh ${cost}?`)) return;
            const res = await fetch('/invest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ city, cost })
            });
            const data = await res.json();
            alert(data.message);
            if (data.success) location.reload();
        }

        async function submitDeposit() {
            const amount = document.getElementById('dep-amount').value;
            const evidence = document.getElementById('dep-evidence').value;
            if(!amount || !evidence) return alert("Please fill all fields");
            
            const res = await fetch('/deposit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount, evidence })
            });
            const data = await res.json();
            alert(data.message);
            closeModal('depositModal');
        }

        async function submitWithdraw() {
            const amount = document.getElementById('wit-amount').value;
            if(amount < 500) return alert("Minimum withdrawal is 500");
            const res = await fetch('/withdraw', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount })
            });
            const data = await res.json();
            alert(data.message);
            closeModal('withdrawModal');
        }
    </script>
</body>
</html>
