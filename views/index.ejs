<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BITREX Platform</title>
  <style>
    *{box-sizing:border-box}body{margin:0;font-family:Georgia,serif;background:#dbe8f5;color:#0f172a}
    .app{max-width:390px;margin:0 auto;min-height:100vh;background:linear-gradient(180deg,#95d4ff 0%,#d7e4f1 55%,#c7e0f6 100%);position:relative;overflow:hidden}
    .city-bg{position:absolute;left:0;right:0;bottom:0;height:130px;background:linear-gradient(180deg,rgba(0,132,255,.05),rgba(0,119,255,.22));filter:blur(.2px)}
    .content{padding:12px 12px 92px;position:relative;z-index:2}
    .logo{display:flex;align-items:center;gap:8px;margin:8px 0 10px}
    .logo .badge{width:52px;height:52px;border-radius:50%;display:grid;place-items:center;background:#1f6fbf;color:#fff;font-weight:700;border:3px solid #6eb6ff}
    .logo .name{font-size:66px;line-height:.9;font-weight:700;color:#245ea7;letter-spacing:1px;font-style:italic}
    .lang{margin-left:auto;font-size:20px}
    .center{text-align:center}
    .subtitle{margin:0;color:#111827;font-size:18px}.muted{color:#334155;margin:4px 0 16px}
    .field{background:#f5f5f5;border:1px solid #94a3b8;border-radius:30px;padding:14px 16px;width:100%;margin:10px 0;font-size:23px}
    .btn{width:100%;border:none;border-radius:30px;background:#4f8fe8;color:#fff;padding:14px;font-size:33px;cursor:pointer;margin-top:8px}
    .link{text-align:center;margin-top:14px;font-size:34px}.link a{color:#b91c1c;text-decoration:none}
    .card{background:#eef2f7;border-radius:16px;padding:12px;margin:10px 0;border:1px solid #d8e0eb}
    .top-stat{background:linear-gradient(180deg,#2e76df,#3d87f5);border-radius:28px;padding:12px;color:#fff;box-shadow:inset 0 0 0 1px rgba(255,255,255,.2)}
    .top-head{display:flex;justify-content:space-between;font-size:30px;margin-bottom:10px}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;background:rgba(255,255,255,.2);padding:8px;border-radius:12px;text-align:center}
    .big{font-size:34px;font-weight:700}.small{font-size:21px;color:#e8f1ff}
    .actions{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.act{background:#f8fafc;border-radius:12px;padding:10px;text-align:center;border:1px solid #e2e8f0;font-size:24px}
    .list-item{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #e2e8f0;padding:12px 6px;font-size:26px}
    .status{font-size:22px;padding:2px 8px;border-radius:20px}.PENDING{background:#fef3c7;color:#92400e}.APPROVED{background:#dcfce7;color:#166534}.REJECTED{background:#fee2e2;color:#991b1b}
    .task-card{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:10px;margin-bottom:10px}
    .task-title{font-size:27px;font-weight:700;color:#1e293b}.task-meta{font-size:20px;color:#64748b;margin:5px 0}
    .task-btn{width:100%;border:none;border-radius:5px;padding:9px;font-size:29px}.task-btn.start{background:#111;color:#90ff70}.task-btn.done{background:#a3a3a3;color:#fff}
    .msg{padding:8px;border-radius:8px;margin:8px 0;font-size:20px}.good{background:#dcfce7;color:#166534}.bad{background:#fee2e2;color:#991b1b}
    .bottom{position:fixed;left:50%;transform:translateX(-50%);bottom:0;width:100%;max-width:390px;background:#f4f4f5;border-top:1px solid #cbd5e1;display:grid;grid-template-columns:repeat(4,1fr);z-index:10}
    .bottom button{background:none;border:none;padding:8px 4px;font-size:20px;cursor:pointer}
    .bottom button.active{color:#2563eb;font-weight:700}
    .hidden{display:none}
    a{text-decoration:none}
  </style>
</head>
<body>
  <div class="app">
    <div class="city-bg"></div>
    <div class="content">
      <% if (error) { %><div class="msg bad"><%= error %></div><% } %>
      <% if (message) { %><div class="msg good"><%= message %></div><% } %>

      <% if (!user) { %>
        <div class="logo"><div class="badge">WD</div><div class="name">PANEX</div><div class="lang">🌐</div></div>

        <section id="auth-signup">
          <h2 class="center subtitle">Begin</h2>
          <p class="center muted">Let's create your account</p>
          <form method="post" action="/signup">
            <input class="field" name="phone" placeholder="+254 7XXXXXXXX" required />
            <input class="field" name="email" type="email" placeholder="Email Address" required />
            <input class="field" name="password" type="password" minlength="6" maxlength="8" placeholder="Password (6-8)" required />
            <input class="field" name="referralCode" placeholder="Referral Code" />
            <button class="btn" type="submit">Go check</button>
          </form>
          <div class="link">Go to <a href="#" onclick="toggleAuth('login');return false;">login</a></div>
        </section>

        <section id="auth-login" class="hidden">
          <h2 class="center subtitle">Welcome back!</h2>
          <p class="center muted">Enter your mobile number to log in</p>
          <form method="post" action="/login">
            <input class="field" name="phone" placeholder="+254 7XXXXXXXX" required />
            <input class="field" name="password" type="password" placeholder="Password" required />
            <button class="btn" type="submit">Login</button>
          </form>
          <div class="link">You don't have an account? <a href="#" onclick="toggleAuth('signup');return false;">Go to register</a></div>
        </section>
      <% } else { %>

      <section id="wallet" class="section">
        <div class="logo" style="margin-bottom:4px;"><div class="badge" style="width:38px;height:38px;font-size:13px;">WD</div><div style="font-size:35px;font-weight:700;color:#1e3a8a;">PANEX</div><div class="lang" style="font-size:14px;">User:<%= user.phone %></div></div>
        <div class="top-stat">
          <div class="top-head"><span>Account balance</span><strong><%= user.balance %></strong></div>
          <div class="stats">
            <div><div class="small">Today's income</div><div class="big"><%= user.todayIncome %></div></div>
            <div><div class="small">This month income</div><div class="big"><%= user.todayIncome * 10 %></div></div>
            <div><div class="small">Total income</div><div class="big"><%= user.totalEarnings %></div></div>
          </div>
        </div>

        <div class="actions">
          <div class="act">💳<br>Account top-up</div>
          <div class="act">📤<br>Withdrawal</div>
          <div class="act">📈<br>Income details</div>
        </div>

        <div class="card">
          <h3 style="margin:0 0 8px;font-size:30px;">My City</h3>
          <% if (!user.activeCities.length) { %>
            <div class="task-meta">No city joined yet.</div>
          <% } else { user.activeCities.forEach(code => { %>
            <div class="list-item">
              <span><%= cityConfig[code].city %> (Day <%= Math.floor((Date.now()-new Date(user.cityJoinDates[code]).getTime())/(1000*60*60*24))+1 %>)</span>
              <span style="color:#16a34a">Completed</span>
            </div>
          <% }) } %>
        </div>
      </section>

      <section id="finance" class="section hidden">
        <div class="card">
          <h3 style="margin:0 0 10px;font-size:36px;">Withdrawal</h3>
          <form action="/withdraw" method="post">
            <input class="field" name="phone" placeholder="Phone to Receive Payment" required />
            <input class="field" name="amount" type="number" min="500" placeholder="Amount (Min KSH 500)" required />
            <input class="field" name="withdrawalPassword" type="password" placeholder="Withdrawal Password" required />
            <button class="btn" type="submit">Submit Withdrawal</button>
          </form>
          <form action="/deposit" method="post" enctype="multipart/form-data" style="margin-top:12px;">
            <input class="field" name="phone" placeholder="Your Phone Number" required />
            <input class="field" name="amount" type="number" min="300" placeholder="Deposit Amount (Min KSH 300)" required />
            <input class="field" type="file" name="evidence" />
            <button class="btn" type="submit">Submit Deposit</button>
          </form>
        </div>
      </section>

      <section id="work" class="section hidden">
        <h3 class="center" style="font-size:40px;margin:0 0 8px;">List of jobs</h3>
        <% const limit = user.activeCities.reduce((s,c)=>s+cityConfig[c].tasksPerDay,0); const reached = user.tasksCompletedToday >= limit; %>
        <% tasks.slice(0,12).forEach((t,i)=>{ %>
          <div class="task-card">
            <div class="task-title"><%= t %></div>
            <div class="task-meta">You can start working every day after midnight.</div>
            <div class="task-meta">Automatic payment upon completion of work 50.00 KSh</div>
            <form method="post" action="/task">
              <input type="hidden" name="taskName" value="<%= t %>" />
              <button class="task-btn <%= reached ? 'done':'start' %>" type="submit" <%= reached ? 'disabled':'' %>><%= reached ? 'Income received':'Start working' %></button>
            </form>
          </div>
        <% }) %>
      </section>

      <section id="homer" class="section hidden">
        <div class="logo" style="margin-bottom:10px;"><div class="badge" style="width:42px;height:42px">WD</div><div style="font-size:31px">User:<%= user.phone %></div></div>
        <div class="card">
          <div class="list-item">Team <span>›</span></div>
          <div class="list-item">My Information <span>›</span></div>
          <div class="list-item">Withdrawal Information <span>›</span></div>
          <div class="list-item">Change login password <span>›</span></div>
          <div class="list-item">Change withdrawal password <span>›</span></div>
          <div class="list-item"><a href="https://wa.me/254106305272" target="_blank">Manager WhatsApp</a> <span>›</span></div>
          <div class="list-item"><a href="/admin">Admin Portal</a> <span>›</span></div>
        </div>

        <div class="card">
          <h3 style="margin:0 0 8px;font-size:28px;">User Profile</h3>
          <input class="field" value="<%= user.phone %>" readonly />
          <input class="field" value="<%= user.email %>" readonly />
          <form action="/profile/password" method="post">
            <input class="field" type="password" name="currentPassword" placeholder="Current password" required />
            <input class="field" type="password" name="newPassword" minlength="6" maxlength="8" placeholder="New password (6-8 characters)" required />
            <button class="btn" type="submit">Update Password</button>
          </form>
        </div>

        <div class="card">
          <h3 style="font-size:28px;margin:0 0 8px;">History of transactions</h3>
          <% if (!user.transactions.length) { %><div class="task-meta">No transactions yet.</div><% } %>
          <% user.transactions.slice(0,20).forEach(tx => { %>
            <div class="list-item" style="font-size:18px;align-items:flex-start;flex-direction:column;">
              <div><strong><%= tx.type %></strong> - KSH <%= tx.amount %> <span class="status <%= tx.status || 'APPROVED' %>"><%= tx.status || 'APPROVED' %></span></div>
              <div style="font-size:14px;color:#475569"><%= tx.detail %> · <%= new Date(tx.date).toLocaleString() %></div>
            </div>
          <% }) %>
        </div>

        <form action="/logout" method="post"><button class="btn" type="submit">Log out</button></form>
      </section>

      <nav class="bottom">
        <button id="tab-work" onclick="switchTab('work')">Work</button>
        <button id="tab-finance" onclick="switchTab('finance')">Finance</button>
        <button id="tab-wallet" class="active" onclick="switchTab('wallet')">Wallet</button>
        <button id="tab-homer" onclick="switchTab('homer')">Homer</button>
      </nav>
      <% } %>
    </div>
  </div>

  <script>
    function toggleAuth(type){
      document.getElementById('auth-signup').classList.toggle('hidden', type!=='signup');
      document.getElementById('auth-login').classList.toggle('hidden', type!=='login');
    }
    function switchTab(id){
      document.querySelectorAll('.section').forEach(s=>s.classList.add('hidden'));
      document.getElementById(id).classList.remove('hidden');
      document.querySelectorAll('.bottom button').forEach(b=>b.classList.remove('active'));
      document.getElementById('tab-'+id).classList.add('active');
    }
  </script>
</body>
</html>
