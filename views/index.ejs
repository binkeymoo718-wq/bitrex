<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX | Dashboard</title>
    <style>
        :root { --blue: #2b7fff; --bg: #f0f4f7; }
        body { font-family: sans-serif; background: var(--bg); margin: 0; padding-bottom: 80px; }
        .hidden { display: none !important; }
        .header { background: var(--blue); color: white; padding: 40px 20px 70px; text-align: center; border-radius: 0 0 35px 35px; position: relative; }
        .user-id { position: absolute; top: 15px; right: 20px; font-weight: bold; }
        .action-container { display: flex; gap: 10px; margin: -40px 15px 20px; position: relative; z-index: 10; }
        .action-btn { background: white; flex: 1; padding: 15px; border-radius: 15px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.1); cursor: pointer; }
        .job-card { background: white; margin: 10px; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center; }
        .nav { position: fixed; bottom: 0; width: 100%; background: white; display: flex; padding: 10px 0; border-top: 1px solid #eee; }
        .nav-item { flex: 1; text-align: center; font-size: 11px; color: #888; cursor: pointer; }
        .nav-item.active { color: var(--blue); font-weight: bold; }
    </style>
</head>
<body>

    <div class="header">
        <div class="user-id"><%= user.phone %></div>
        <div style="font-size: 14px;">Account balance</div>
        <div style="font-size: 36px; font-weight: 800;">Ksh <%= user.balance %></div>
    </div>

    <div class="action-container">
        <div class="action-btn" onclick="toggleModal('deposit', true)"><span>💳 Top-up</span></div>
        <div class="action-btn" onclick="toggleModal('withdraw', true)"><span>📥 Withdraw</span></div>
        <div class="action-btn" onclick="showSec('menu', this)"><span>👤 Profile</span></div>
    </div>

    <div id="home-sec">
        <div style="margin: 15px; font-weight: bold;">Income Today: Ksh <%= user.todays_income || 0 %></div>
        <div class="job-card">
            <% if (userCities.length > 0) { %>
                <% userCities.forEach(city => { %> <div>🏙️ <b><%= city.city_name %></b> - Active</div> <% }); %>
            <% } else { %> <p style="text-align: center;">Join a City to start earning.</p> <% } %>
        </div>
    </div>

    <div id="task-sec" class="hidden">
        <div class="job-card">
            <b>Smart Tech Task</b><p>Reward: Ksh 50</p>
            <button onclick="doTask()" style="background:black; color:white; width:100%; padding:10px; border:none; border-radius:5px;">Claim Reward</button>
        </div>
    </div>

    <div id="deposit-modal" class="overlay hidden">
        <div style="background:white; padding:20px; border-radius:15px; width:80%;">
            <h3>Top-up</h3>
            <p>Till Number: <b>9147551</b> (BINKEY)</p>
            <input type="number" id="d-amt" placeholder="Amount" style="width:100%; padding:10px; margin-bottom:10px;">
            <input type="text" id="d-ev" placeholder="M-PESA Code" style="width:100%; padding:10px; margin-bottom:10px;">
            <button onclick="submitDep()" style="background:var(--blue); color:white; width:100%; padding:10px; border:none; border-radius:5px;">Submit</button>
            <button onclick="toggleModal('deposit', false)" style="width:100%; border:none; background:none; margin-top:10px;">Cancel</button>
        </div>
    </div>

    <div id="menu-sec" class="hidden">
        <div class="job-card">
            <p><b>Referral Link:</b></p>
            <div onclick="copyLink()" style="background:#eee; padding:10px; border-radius:5px; font-size:12px; cursor:pointer; color:var(--blue);">
                http://bitrex.com/signup?ref=<%= user.referral_code %>
            </div>
            <p style="font-size:10px; color:#999;">(Click to copy & share)</p>
            <button onclick="location.href='/logout'" style="background:#ff4d4d; color:white; width:100%; padding:10px; margin-top:20px; border:none; border-radius:5px;">Logout</button>
        </div>
    </div>

    <div class="nav">
        <div class="nav-item active" onclick="showSec('home', this)">🏠<br>Home</div>
        <div class="nav-item" onclick="showSec('task', this)">⚡<br>Task</div>
        <div class="nav-item" onclick="showSec('menu', this)">👤<br>Menu</div>
    </div>

    <script>
        function showSec(id, el) {
            ['home', 'task', 'menu'].forEach(s => document.getElementById(s + '-sec').classList.add('hidden'));
            document.getElementById(id + '-sec').classList.remove('hidden');
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            el.classList.add('active');
        }
        function toggleModal(type, show) { document.getElementById(type + '-modal').classList[show ? 'remove' : 'add']('hidden'); }
        
        async function submitDep() {
            const amount = document.getElementById('d-amt').value;
            const evidence = document.getElementById('d-ev').value;
            const res = await fetch('/deposit', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ amount, evidence, user_id: '<%= user.id %>' }) });
            const data = await res.json(); alert(data.message); if(data.success) toggleModal('deposit', false);
        }

        async function doTask() {
            const res = await fetch('/claim_task', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ user_id: '<%= user.id %>' }) });
            const data = await res.json(); alert(data.message); if(data.success) location.reload();
        }

        function copyLink() {
            const link = "http://bitrex.com/signup?ref=<%= user.referral_code %>";
            navigator.clipboard.writeText(link);
            alert("Referral link copied to clipboard!");
        }
    </script>
</body>
</html>
