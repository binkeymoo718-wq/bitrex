<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .gradient-main { background: linear-gradient(180deg, #3b82f6 0%, #ffffff 100%); min-height: 100vh; }
        .bottom-nav { position: fixed; bottom: 0; left: 0; width: 100%; display: flex; justify-content: space-around; background: white; padding: 12px; border-top: 2px solid #f0f0f0; z-index: 100; }
        .hidden-tab { display: none; }
        .tab-btn { font-weight: bold; font-size: 12px; color: #666; }
        .tab-btn.active { color: #2563eb; }
    </style>
</head>
<body class="gradient-main pb-24">

    <div id="homer-tab" class="p-5">
        <div class="flex justify-between items-center text-white mb-6">
            <h1 class="text-2xl font-black italic">BITREX</h1>
            <span class="bg-blue-800 px-3 py-1 rounded-full text-xs">ID: <%= user.phone %></span>
        </div>

        <div class="bg-blue-600 rounded-2xl p-6 text-white shadow-xl mb-6">
            <p class="text-xs opacity-70 mb-1">Total Balance</p>
            <p class="text-3xl font-bold mb-4">KSh <%= user.balance || 0 %></p>
            <div class="grid grid-cols-2 gap-4 border-t border-blue-400 pt-4">
                <div><p class="text-[10px] uppercase">Today's Income</p><p class="font-bold">KSh <%= user.today_income || 0 %></p></div>
                <div><p class="text-[10px] uppercase">Active Cities</p><p class="font-bold">Joined</p></div>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-8">
            <button class="bg-white p-4 rounded-xl shadow font-bold text-blue-600">Deposit</button>
            <button class="bg-white p-4 rounded-xl shadow font-bold text-red-500">Withdraw</button>
        </div>

        <div class="bg-white rounded-2xl shadow overflow-hidden">
            <div class="p-4 border-b flex justify-between" onclick="alert('Invite Code: <%= user.referral_code %>')"><span>Team</span><span>></span></div>
            <div class="p-4 border-b flex justify-between"><span>My Information</span><span>></span></div>
            <div class="p-4 border-b flex justify-between" onclick="window.location.href='https://wa.me/254106305272'"><span>Manager WhatsApp</span><span>></span></div>
            <div class="p-4 border-b flex justify-between" onclick="window.location.href='https://whatsapp.com/channel/0029VbCayoOA2pLHtre2dP3Jnel'"><span>WhatsApp Channel</span><span>></span></div>
            <div class="p-4 text-center text-red-500 font-bold" onclick="window.location.href='/login'">Log Out</div>
        </div>
    </div>

    <div id="work-tab" class="p-5 hidden-tab">
        <h2 class="text-xl font-bold mb-6 text-blue-900">Available Tasks</h2>
        <div class="space-y-4">
            <div class="bg-white p-4 rounded-xl shadow flex justify-between items-center">
                <div><p class="font-bold">2.5L Vacuum Flask</p><p class="text-xs text-green-600">Commission: KSh 50</p></div>
                <button onclick="handleTask()" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-xs font-bold">Start Working</button>
            </div>
            </div>
    </div>

    <div id="wallet-tab" class="p-5 hidden-tab text-center pt-20">
        <h2 class="text-2xl font-bold">Transaction History</h2>
        <p class="text-gray-500 mt-2">No recent transactions to display.</p>
    </div>

    <nav class="bottom-nav">
        <button onclick="showTab('work')" class="tab-btn" id="btn-work">WORK</button>
        <button onclick="showTab('wallet')" class="tab-btn" id="btn-wallet">WALLET</button>
        <button onclick="showTab('homer')" class="tab-btn active" id="btn-homer">HOMER</button>
    </nav>

    <script>
        function showTab(tabName) {
            document.querySelectorAll('[id$="-tab"]').forEach(tab => tab.classList.add('hidden-tab'));
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById(tabName + '-tab').classList.remove('hidden-tab');
            document.getElementById('btn-' + tabName).classList.add('active');
        }

        async function handleTask() {
            // Task logic placeholder
            alert("Checking limits...");
        }
    </script>
</body>
</html>
