<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX | Dashboard</title>
    <style>
        :root { --primary-blue: #2b7fff; --bg: #f0f4f7; }
        body { font-family: sans-serif; background: var(--bg); margin: 0; padding-bottom: 80px; }
        .hidden { display: none !important; }
        
        .header { background: var(--primary-blue); color: white; padding: 40px 20px 70px; text-align: center; border-radius: 0 0 35px 35px; position: relative; }
        .balance-box { font-size: 40px; font-weight: 800; margin: 10px 0; }
        
        .action-container { display: flex; gap: 10px; margin: -40px 15px 20px; position: relative; z-index: 10; }
        .action-btn { background: white; flex: 1; padding: 15px; border-radius: 15px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.1); cursor: pointer; }

        .job-card { background: white; margin: 10px; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center; }
        
        .nav { position: fixed; bottom: 0; width: 100%; background: white; display: flex; padding: 10px 0; border-top: 1px solid #eee; }
        .nav-item { flex: 1; text-align: center; font-size: 11px; color: #888; cursor: pointer; }
        .nav-item.active { color: var(--primary-blue); font-weight: bold; }
    </style>
</head>
<body>

    <div class="header">
        <div style="font-size: 14px; opacity: 0.9;">Account balance</div>
        <div class="balance-box">Ksh <%= user.balance %></div>
        <div style="display: flex; justify-content: space-around; margin-top: 20px;">
            <div><small>Today</small><br><b><%= user.todays_income || 0 %></b></div>
            <div><small>Month</small><br><b><%= user.monthly_income || 0 %></b></div>
            <div><small>Total</small><br><b><%= user.total_income || 0 %></b></div>
        </div>
    </div>

    <div class="action-container">
        <div class="action-btn" onclick="toggleModal('deposit', true)"><span>💳 Top-up</span></div>
        <div class="action-btn" onclick="toggleModal('withdraw', true)"><span>📥 Withdraw</span></div>
        <div class="action-btn" onclick="showSec('menu', this)"><span>👤 Profile</span></div>
    </div>

    <div id="home-sec">
        <div style="margin: 15px; font-weight: bold;">Active City</div>
        <div class="job-card">
            <% if (userCities.length > 0) { %>
                <% userCities.forEach(city => { %>
                    <div style="padding: 10px 0;">🏙️ <b><%= city.city_name %></b> - Active</div>
                <% }); %>
            <% } else { %>
                <p style="text-align: center; color: #999;">No cities joined.</p>
            <% } %>
        </div>
    </div>

    <div id="task-sec" class="hidden">
        <div class="job-card">
            <h4>Daily Job List</h4>
            <p>Click below to complete your daily work.</p>
            <button onclick="doTask()" style="background:black; color:white; width:100%; padding:12px; border-radius:5px; border:none;">Start working</button>
        </div>
    </div>

    <div id="withdraw-modal" class="overlay hidden">
        <div style="background:white; padding:20px; border-radius:15px; width:85%; max-width:400px;">
            <h3>Withdraw</h3>
            <p>Min Withdrawal: Ksh 500</p>
            <input type="number" id="wit-amt" placeholder="Amount" style="width:100%; padding:10px; margin-bottom:10px; box-sizing:border-box;">
            <button onclick="submitWit()" style="background:var(--primary-blue); color:white; width:100%; padding:12px; border:none; border-radius:8px;">Withdraw Now</button>
            <button onclick="toggleModal('withdraw', false)" style="width:100%; padding:10px; border:none; background:none; margin-top:10px;">Cancel</button>
        </div>
    </div>

    <div id="deposit-modal" class="overlay hidden">
        <div style="background:white; padding:20px; border-radius:15px; width:85%; max-width:400px;">
            <h3>Top-up</h3>
            <p>Send to: 0733319700</p>
            <input type="number" id="dep-amt" placeholder="Amount" style="width:100%; padding:10px; margin-bottom:10px; box-sizing:border-box;">
            <input type="text" id="dep-code" placeholder="M-PESA Code" style="width:100%; padding:10px; margin-bottom:10px; box-sizing:border-box;">
            <button onclick="alert('Submitted')" style="background:var(--primary-blue); color:white; width:100%; padding:12px; border:none; border-radius:8px;">Submit</button>
            <button onclick="toggleModal('deposit', false)" style="width:100%; padding:10px; border:none; background:none; margin-top:10px;">Close</button>
        </div>
    </div>

    <div class="nav">
        <div class="nav-item active" onclick="showSec('home', this)">🏠<br>Home</div>
        <div class="nav-item" onclick="showSec('task', this)">⚡<br>Task</div>
        <div class="nav-item" onclick="showSec('menu', this)">👤<br>Menu</div>
    </div>

    <script>
        function showSec(id, el) {
            ['home', 'task', 'menu'].forEach(s => document.getElementById(s + '-sec').classList.add('hidden'));
            document.getElementById(id + '-sec').classList.remove('hidden');
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            el.classList.add('active');
        }

        function toggleModal(type, show) {
            const modal = document.getElementById(type + '-modal');
            if (show) modal.classList.remove('hidden');
            else modal.classList.add('hidden');
        }

        async function doTask() {
            const res = await fetch('/claim_task', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ user_id: '<%= user.id %>' }) });
            const data = await res.json();
            alert(data.message);
            if(data.success) location.reload();
        }

        async function submitWit() {
            const amount = document.getElementById('wit-amt').value;
            const res = await fetch('/withdraw', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ amount, user_id: '<%= user.id %>' }) });
            const data = await res.json();
            alert(data.message);
            if(data.success) location.reload();
        }
    </script>
</body>
</html>
