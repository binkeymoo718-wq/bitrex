<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #635BFF; --bg: #F8FAFC; --card: #FFFFFF; --text: #1E293B; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .logo { font-weight: 800; font-size: 1.5rem; color: var(--primary); }
        .balance-card { background: var(--primary); color: white; padding: 30px; border-radius: 24px; box-shadow: 0 10px 20px rgba(99, 91, 255, 0.2); margin-bottom: 30px; }
        .balance-label { font-size: 0.9rem; opacity: 0.9; }
        .balance-amount { font-size: 2.5rem; font-weight: 700; margin: 10px 0; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
        .invest-card { background: var(--card); padding: 20px; border-radius: 20px; border: 1px solid #E2E8F0; transition: 0.3s; }
        .invest-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .city-name { font-weight: 700; font-size: 1.2rem; margin-bottom: 5px; }
        .price { color: var(--primary); font-weight: 700; font-size: 1.1rem; }
        .btn-invest { width: 100%; padding: 12px; background: #F1F5F9; border: none; border-radius: 10px; font-weight: 600; cursor: pointer; margin-top: 15px; }
        .btn-invest:hover { background: var(--primary); color: white; }
    </style>
</head>
<body>

    <div class="header">
        <div class="logo">BITREX</div>
        <div>Welcome, <strong><%= user.name %></strong></div>
    </div>

    <div class="balance-card">
        <div class="balance-label">Total Balance</div>
        <div class="balance-amount">Ksh <%= user.balance %></div>
        <div style="font-size: 0.8rem;">Status: Active Account</div>
    </div>

    <h3>Investment Packages</h3>
    <div class="grid">
        <div class="invest-card">
            <div class="city-name">Nakuru City</div>
            <div class="price">Ksh 500</div>
            <p>Daily Earn: Ksh 50</p>
            <button class="btn-invest">Invest Now</button>
        </div>

        <div class="invest-card">
            <div class="city-name">Lodwar Town</div>
            <div class="price">Ksh 1,000</div>
            <p>Daily Earn: Ksh 110</p>
            <button class="btn-invest">Invest Now</button>
        </div>
        
        <div class="invest-card">
            <div class="city-name">Nairobi Hub</div>
            <div class="price">Ksh 5,000</div>
            <p>Daily Earn: Ksh 600</p>
            <button class="btn-invest">Invest Now</button>
        </div>
    </div>

</body>
</html>
