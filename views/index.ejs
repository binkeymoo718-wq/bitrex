<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BITREX</title>
    <style>
        :root { --blue: #3B82F6; --bg: #F3F4F6; }
        body { font-family: sans-serif; background: var(--bg); margin: 0; padding-bottom: 80px; }
        .top-id { text-align: right; padding: 10px 20px; background: var(--blue); color: white; font-weight: bold; font-size: 0.8rem; }
        .stats { background: linear-gradient(var(--blue), #2563EB); color: white; padding: 30px 20px 60px; text-align: center; border-radius: 0 0 35px 35px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; padding: 0 20px; margin-top: -30px; }
        .card { background: white; padding: 15px; border-radius: 15px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .hidden { display: none; }
        .nav { position: fixed; bottom: 0; width: 100%; background: white; display: flex; border-top: 1px solid #DDD; }
        .nav-item { flex: 1; text-align: center; padding: 12px; font-size: 0.7rem; color: #888; cursor: pointer; }
        .nav-item.active { color: var(--blue); font-weight: bold; }
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 2000; }
        .modal-box { background: white; margin: 20% auto; padding: 25px; border-radius: 20px; width: 80%; max-width: 400px; }
        input { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #DDD; border-radius: 8px; box-sizing: border-box; }
    </style>
</head>
<body>

<div class="top-id">ID: <%= user.phone %></div>

<div id="home-sec">
    <div class="stats">
        <div style="opacity: 0.8;">Account balance</div>
        <h1 style="margin: 10px 0;">Ksh <%= user.balance %></h1>
        <div style="display: flex; justify-content: space-around; font-size: 0.75rem;">
            <div>Today<br><b><%= user.todays_income || 0 %></b></div>
            <div>Month<br><b><%= user.monthly_income || 0 %></b></div>
            <div>Total<br><b><%= user.total_income || 0 %></b></div>
        </div>
    </div>
    <div class="grid">
        <div class="card" onclick="showModal('depModal')">💳<br>Top-up</div>
        <div class="card" onclick="showModal('witModal')">📥<br>Withdraw</div>
        <div class="card">📊<br>Details</div>
    </div>
    <div style="padding: 20px;">
        <h4 style="margin-bottom: 10px;">Joined Cities</h4>
        <% if (userCities && userCities.length > 0) { %>
            <% userCities.forEach(city => { %>
                <div style="background:white; padding:15px; border-radius:12px; margin-bottom:10px; display:flex; justify-content:space-between;">
                    <b>🏙️ <%= city.city_name %></b>
                    <span style="color:#10B981;">Daily: Ksh <%= city.daily_income %></span>
                </div>
            <% }); %>
        <% } %>
    </div>
</div>

<div id="task-sec" class="hidden" style="padding: 20px;">
    <h3>Daily Tasks</h3>
    <button onclick="claimTask()" style="width:100%; background:var(--blue); color:white; border:none; padding:15px; border-radius:12px;">Claim All City Rewards</button>
</div>

<div id="depModal" class="modal"><div class="modal-box">
    <h3>Top-up</h3>
    <input type="number" id="d_amt" placeholder="Amount">
    <input type="text" id="d_msg" placeholder="M-PESA Message">
    <button onclick="submitDeposit()" style="width:100%; background:var(--blue); color:white; border:none; padding:12px; border-radius:8px;">Submit</button>
</div></div>

<div id="witModal" class="modal"><div class="modal-box">
    <h3>Withdrawal</h3>
    <input type="number" id="w_amt" placeholder="Amount (Min 500)">
    <button onclick="submitWithdraw()" style="width:100%; background:var(--blue); color:white; border:none; padding:12px; border-radius:8px;">Withdraw</button>
</div></div>

<nav class="nav">
    <div class="nav-item active" onclick="tab('home', this)">🏠<br>Home</div>
    <div class="nav-item" onclick="tab('task', this)">⚡<br>Task</div>
    <div class="nav-item" onclick="tab('menu', this)">👤<br>MENU</div>
</nav>

<script>
    function tab(id, el) {
        ['home', 'task', 'menu'].forEach(s => { if(document.getElementById(s+'-sec')) document.getElementById(s+'-sec').classList.add('hidden') });
        document.getElementById(id+'-sec').classList.remove('hidden');
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        el.classList.add('active');
    }
    function showModal(id) { document.getElementById(id).style.display='block'; }
    async function claimTask() {
        const res = await fetch('/claim_task', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ user_id: '<%= user.id %>' }) });
        const d = await res.json(); alert(d.message); if(d.success) location.reload();
    }
</script>
</body>
</html>
