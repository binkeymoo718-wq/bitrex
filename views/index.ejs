<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BITREX Platform</title>
  <style>
    :root{--bg:#0b1220;--card:#111827;--muted:#94a3b8;--line:#233047;--ok:#22c55e;--bad:#ef4444;--primary:#3b82f6}
    *{box-sizing:border-box}
    body{margin:0;font-family:Inter,Arial,sans-serif;background:linear-gradient(180deg,#020617,#0b1220);color:#e2e8f0}
    .container{max-width:980px;margin:0 auto;padding:16px 16px 92px}
    .card{background:rgba(17,24,39,.95);border:1px solid var(--line);border-radius:14px;padding:16px;margin-bottom:14px}
    .hero{background:linear-gradient(90deg,#1d4ed8,#0f766e)}
    h2,h3{margin:0 0 8px}
    .small{font-size:.9rem;color:var(--muted)}
    .msg{padding:10px 12px;border-radius:10px;margin-bottom:12px}
    .msg.ok{background:#052e1a;color:#86efac}.msg.err{background:#3f0a0a;color:#fca5a5}
    input,select,button{width:100%;padding:11px 12px;border-radius:10px;border:1px solid #314158;background:#0a1325;color:#e2e8f0;margin:6px 0}
    button{border:none;background:linear-gradient(90deg,#2563eb,#22c55e);font-weight:600;cursor:pointer}
    .btn-red{background:linear-gradient(90deg,#991b1b,#ef4444)}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .pill{padding:10px;border:1px solid var(--line);background:#0b1426;border-radius:10px}
    .topbar{display:flex;justify-content:space-between;align-items:center;gap:10px}
    table{width:100%;border-collapse:collapse}
    th,td{font-size:.9rem;padding:8px;border-bottom:1px solid #1f2c42;text-align:left}
    .section{display:none}.section.active{display:block}
    .status{padding:2px 8px;border-radius:999px;font-size:.78rem;font-weight:700}
    .PENDING{background:#78350f;color:#fde68a}.APPROVED{background:#14532d;color:#bbf7d0}.REJECTED{background:#7f1d1d;color:#fecaca}
    .badge-link{display:inline-block;padding:6px 10px;border:1px solid #7dd3fc;border-radius:999px;background:#0c4a6e;color:#cffafe;text-decoration:none;font-size:.8rem}
    .bottom-nav{position:fixed;left:50%;transform:translateX(-50%);bottom:0;width:100%;max-width:980px;background:#020617;border-top:1px solid #1e293b;display:grid;grid-template-columns:repeat(4,1fr);z-index:10}
    .bottom-nav button{margin:0;border-radius:0;border-right:1px solid #1e293b;background:#0b1220}
    @media(max-width:800px){.row,.stats{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <div class="container">
    <% if (error) { %><div class="msg err"><%= error %></div><% } %>
    <% if (message) { %><div class="msg ok"><%= message %></div><% } %>

    <% if (!user) { %>
      <div class="card hero">
        <h2>Welcome to BITREX Business Platform</h2>
        <p class="small" style="color:#dbeafe">Create account, invest in city packages, complete daily tasks and track earnings.</p>
      </div>
      <div class="row">
        <div class="card">
          <h3>Sign Up</h3>
          <form method="post" action="/signup">
            <input name="phone" placeholder="Phone Number" required />
            <input name="email" type="email" placeholder="Email Address" required />
            <input name="password" type="password" minlength="6" maxlength="8" placeholder="Password (6-8 chars)" required />
            <input name="referralCode" placeholder="Referral Code (Optional)" />
            <button type="submit">Create Account</button>
          </form>
        </div>
        <div class="card">
          <h3>Login</h3>
          <form method="post" action="/login">
            <input name="phone" placeholder="Phone Number" required />
            <input name="password" type="password" placeholder="Password" required />
            <button type="submit">Log In</button>
          </form>
          <p class="small">Admin? <a href="/admin" style="color:#93c5fd">Open Admin Portal</a></p>
        </div>
      </div>
    <% } else { %>
      <div class="card topbar">
        <div>
          <h3>BITREX Dashboard</h3>
          <div class="small">Registered Number: <strong><%= user.phone %></strong></div>
        </div>
        <div style="display:flex;gap:8px;align-items:center;">
          <a href="/admin" class="badge-link">Admin Portal</a>
          <form action="/logout" method="post"><button class="btn-red" style="width:auto;padding:10px 14px;">Logout</button></form>
        </div>
      </div>

      <section id="home" class="section active">
        <div class="card stats">
          <div class="pill"><div class="small">Balance</div><strong>KSH <%= user.balance %></strong></div>
          <div class="pill"><div class="small">Today's Income</div><strong>KSH <%= user.todayIncome %></strong></div>
          <div class="pill"><div class="small">Total Earnings</div><strong>KSH <%= user.totalEarnings %></strong></div>
        </div>

        <div class="card">
          <h3>Active Investments</h3>
          <% if (!user.activeCities.length) { %><p class="small">No city joined yet.</p><% } else { %>
          <table>
            <thead><tr><th>City</th><th>Days</th><th>Daily Income</th></tr></thead>
            <tbody>
              <% user.activeCities.forEach(code => { %>
                <tr>
                  <td><%= cityConfig[code].city %></td>
                  <td><%= Math.floor((Date.now()-new Date(user.cityJoinDates[code]).getTime())/(1000*60*60*24))+1 %></td>
                  <td>KSH <%= cityConfig[code].dailyIncome %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>

        <div class="row">
          <div class="card">
            <h3>Deposit (Min KSH 300)</h3>
            <p class="small">Send money to <strong>0733319700</strong>. Reflected after admin approval.</p>
            <form action="/deposit" method="post" enctype="multipart/form-data">
              <input name="phone" placeholder="Your Phone Number" required />
              <input name="amount" type="number" min="300" placeholder="Amount" required />
              <input type="file" name="evidence" />
              <button type="submit">Submit Deposit</button>
            </form>
          </div>
          <div class="card">
            <h3>Withdraw (Min KSH 500)</h3>
            <form action="/withdraw" method="post">
              <input name="phone" placeholder="Phone to Receive Payment" required />
              <input name="amount" type="number" min="500" placeholder="Amount" required />
              <input name="withdrawalPassword" type="password" placeholder="Withdrawal Password" required />
              <button type="submit">Withdraw</button>
            </form>
          </div>
        </div>
      </section>

      <section id="task" class="section">
        <div class="card">
          <h3>Daily Tasks (KSH 50 each)</h3>
          <p class="small">Tasks reset after midnight and are limited by joined city packages.</p>
          <form method="post" action="/task">
            <select name="taskName" required>
              <option value="">Select task</option>
              <% tasks.forEach(t => { %><option value="<%= t %>"><%= t %> - KSH 50</option><% }) %>
            </select>
            <button type="submit">Complete Task</button>
          </form>
          <p class="small">Tasks completed today: <%= user.tasksCompletedToday %> / <%= user.activeCities.reduce((s,c)=>s+cityConfig[c].tasksPerDay,0) %></p>
        </div>
      </section>

      <section id="city" class="section">
        <div class="card">
          <h3>City Investments</h3>
          <table>
            <thead><tr><th>City</th><th>Amount</th><th>Task/day</th><th>Daily Income</th><th></th></tr></thead>
            <tbody>
              <% Object.keys(cityConfig).forEach(code => { const c=cityConfig[code]; %>
                <tr>
                  <td><%= c.city %></td><td>KSH <%= c.amount %></td><td><%= c.tasksPerDay %></td><td>KSH <%= c.dailyIncome %></td>
                  <td><form method="post" action="/invest/<%= code %>"><button type="submit">Join</button></form></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section id="menu" class="section">
        <div class="card">
          <h3>Menu</h3>
          <p>Manager WhatsApp: <a href="https://wa.me/254106305272" target="_blank" class="badge-link">+254106305272</a></p>
          <p>Your Referral Code: <strong><%= user.referralCode %></strong></p>
          <p>Referrals: <%= user.referredCount %> / 5 friends (bonus KSH 300 one-time).</p>
        </div>

        <div class="card">
          <h3>User Profile</h3>
          <input value="<%= user.phone %>" readonly />
          <input value="<%= user.email %>" readonly />
          <form action="/profile/password" method="post">
            <input type="password" name="currentPassword" placeholder="Current password" required />
            <input type="password" name="newPassword" minlength="6" maxlength="8" placeholder="New password (6-8 characters)" required />
            <button type="submit">Update Password</button>
          </form>
        </div>

        <div class="card">
          <h3>Transaction History</h3>
          <% if (!user.transactions.length) { %><p class="small">No transactions yet.</p><% } %>
          <table>
            <thead><tr><th>Type</th><th>Amount</th><th>Status</th><th>Detail</th><th>Date</th></tr></thead>
            <tbody>
              <% user.transactions.slice(0,20).forEach(tx => { %>
                <tr>
                  <td><%= tx.type %></td>
                  <td>KSH <%= tx.amount %></td>
                  <td><span class="status <%= tx.status || 'APPROVED' %>"><%= tx.status || 'APPROVED' %></span></td>
                  <td><%= tx.detail %></td>
                  <td><%= new Date(tx.date).toLocaleString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <nav class="bottom-nav">
        <button onclick="switchTab('home')">🏠 Home</button>
        <button onclick="switchTab('task')">✅ Task</button>
        <button onclick="switchTab('city')">🏙️ City</button>
        <button onclick="switchTab('menu')">☰ Menu</button>
      </nav>
      <script>
        function switchTab(id){
          document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
          document.getElementById(id).classList.add('active');
        }
      </script>
    <% } %>
  </div>
</body>
</html>
