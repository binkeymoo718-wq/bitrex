<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BITREX | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root { --blue-main: #3B82F6; --bg-light: #F3F4F6; }
        body { font-family: 'Inter', sans-serif; background: var(--bg-light); margin: 0; padding-bottom: 90px; color: #1F2937; }
        
        /* Top Blue Stats Card - Matches PANEX Style */
        .stats-header { background: linear-gradient(180deg, #3B82F6 0%, #2563EB 100%); color: white; padding: 30px 20px 50px 20px; border-bottom-left-radius: 30px; border-bottom-right-radius: 30px; text-align: center; position: relative; }
        .balance-label { font-size: 0.85rem; opacity: 0.9; margin-bottom: 5px; }
        .balance-main { font-size: 2.2rem; font-weight: 700; margin-bottom: 20px; }
        
        .income-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; background: rgba(255, 255, 255, 0.15); border-radius: 20px; padding: 15px; backdrop-filter: blur(5px); }
        .income-item div:first-child { font-size: 0.7rem; opacity: 0.8; margin-bottom: 8px; text-transform: uppercase; }
        .income-item div:last-child { font-weight: 700; font-size: 1.1rem; }

        /* Quick Action Grid (Top-up/Withdraw) */
        .action-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; padding: 0 20px; margin-top: -30px; position: relative; z-index: 10; }
        .action-card { background: white; padding: 18px 10px; border-radius: 18px; text-align: center; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); cursor: pointer; transition: transform 0.2s; }
        .action-card:active { transform: scale(0.95); }
        .action-icon { font-size: 1.6rem; margin-bottom: 8px; display: block; }
        .action-label { font-size: 0.75rem; font-weight: 600; color: #4B5563; }

        /* My City Section */
        .section-container { padding: 20px; }
        .section-title { font-size: 1rem; font-weight: 700; margin-bottom: 12px; display: block; }
        .city-status-card { background: white; padding: 15px; border-radius: 20px; display: flex; align-items: center; gap: 15px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
        .city-img-box { width: 90px; height: 65px; border-radius: 12px; background: #E5E7EB; background-size: cover; background-position: center; }
        .city-info { flex: 1; }
        .city-name { font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
        .city-days { font-size: 0.75rem; color: #9CA3AF; }
        .city-badge { color: #F97316; font-weight: 700; font-size: 0.8rem; }

        /* Bottom Nav - Fixed with Home, Task, City */
        .bottom-nav { position: fixed; bottom: 0; width: 100%; background: white; display: flex; justify-content: space-around; padding: 12px 0; border-top: 1px solid #E5E7EB; z-index: 1000; }
        .nav-item { text-align: center; font-size: 0.7rem; color: #9CA3AF; text-decoration: none; font-weight: 500; }
        .nav-item.active { color: var(--blue-main); }
        .nav-icon { font-size: 1.4rem; margin-bottom: 4px; display: block; }

        /* Hidden Sections */
        .hidden { display: none; }
        .task-list { padding: 15px; }
        .task-card { background: white; margin-bottom: 10px; padding: 15px; border-radius: 15px; display: flex; justify-content: space-between; align-items: center; }
    </style>
</head>
<body>

<div id="home-sec">
    <div class="stats-header">
        <div class="balance-label">Account balance</div>
        <div class="balance-main">Ksh <%= user.balance %></div>
        
        <div class="income-grid">
            <div class="income-item">
                <div>Today's income</div>
                <div><%= user.todays_income || 0 %></div>
            </div>
            <div class="income-item">
                <div>This month's</div>
                <div><%= user.monthly_income || 0 %></div>
            </div>
            <div class="income-item">
                <div>Total income</div>
                <div><%= user.total_income || 0 %></div>
            </div>
        </div>
    </div>

    <div class="action-grid">
        <div class="action-card" onclick="location.href='/deposit'">
            <span class="action-icon">💳</span>
            <span class="action-label">Account top-up</span>
        </div>
        <div class="action-card" onclick="location.href='/withdraw'">
            <span class="action-icon">📥</span>
            <span class="action-label">Withdrawal</span>
        </div>
        <div class="action-card">
            <span class="action-icon">📈</span>
            <span class="action-label">Income details</span>
        </div>
    </div>

    <div class="section-container">
        <span class="section-title">My City</span>
        <div class="city-status-card">
            <div class="city-img-box" style="background-image: url('https://images.unsplash.com/photo-1514924013411-cbf25faa35bb?q=80&w=200');"></div>
            <div class="city-info">
                <div class="city-name"><%= user.active_city || 'None' %></div>
                <div class="city-days">Joined Time <%= user.days_worked || 0 %>/365</div>
            </div>
            <div class="city-badge">
                <%= user.active_city !== 'None' ? 'Completed' : 'Pending' %>
            </div>
        </div>
    </div>
</div>

<div id="task-sec" class="hidden">
    <div style="padding: 20px; background: white; text-align: center; border-bottom: 1px solid #EEE;">
        <h3 style="margin: 0;">Daily Tasks</h3>
    </div>
    <div class="task-list">
        <% const products = ['2.5L Vaccum Flask', 'Mini massage gun', 'Blood glucose machine', 'Electric blender', 'Modern soldering gun', 'Television set', 'Electric meter', 'Smart phones', 'HD Camera High pixel', 'Iron sheets', 'Plumbing tools', 'Furniture', 'Wi-Fi systems', 'Laptops', 'Textiles', 'Paints', 'Cosmetics', 'Electrical tools', 'Shoes', 'Gas cookers', 'Electric heater']; %>
        <% products.forEach(p => { %>
            <div class="task-card">
                <div>
                    <div style="font-weight:600; font-size:0.9rem;"><%= p %></div>
                    <div style="color:var(--blue-main); font-size:0.8rem; font-weight:700;">Reward: Ksh 50</div>
                </div>
                <button onclick="claimTask()" style="background:var(--blue-main); color:white; border:none; padding:8px 15px; border-radius:10px; font-weight:600; font-size:0.8rem;">Claim</button>
            </div>
        <% }); %>
    </div>
</div>

<div id="city-sec" class="hidden">
    <div style="padding: 20px;">
        <h3>Investment Cities</h3>
        <div style="display: grid; gap: 15px;">
            <% const tiers = [['CITY A', 1500, 50], ['CITY B', 3200, 110], ['CITY C', 7200, 250], ['CITY D', 15000, 600]]; %>
            <% tiers.forEach(t => { %>
                <div style="background:white; padding:20px; border-radius:20px; display:flex; justify-content:space-between; align-items:center;">
                    <div>
                        <div style="font-weight:700;"><%= t[0] %></div>
                        <div style="font-size:0.8rem; color:#6B7280;">Cost: Ksh <%= t[1] %></div>
                        <div style="font-size:0.8rem; color:#059669; font-weight:600;">Daily: Ksh <%= t[2] %></div>
                    </div>
                    <button onclick="invest('<%= t[0] %>', <%= t[1] %>)" style="background:var(--blue-main); color:white; border:none; padding:10px 20px; border-radius:12px; font-weight:600;">Invest</button>
                </div>
            <% }); %>
        </div>
    </div>
</div>

<nav class="bottom-nav">
    <a href="javascript:void(0)" class="nav-item active" onclick="switchTab('home', this)">
        <span class="nav-icon">🏠</span>Home
    </a>
    <a href="javascript:void(0)" class="nav-item" onclick="switchTab('task', this)">
        <span class="nav-icon">⚡</span>Task
    </a>
    <a href="javascript:void(0)" class="nav-item" onclick="switchTab('city', this)">
        <span class="nav-icon">🏙️</span>City
    </a>
</nav>

<script>
    function switchTab(tabId, el) {
        // Hide all
        document.getElementById('home-sec').classList.add('hidden');
        document.getElementById('task-sec').classList.add('hidden');
        document.getElementById('city-sec').classList.add('hidden');
        
        // Show selected
        document.getElementById(tabId + '-sec').classList.remove('hidden');
        
        // Update nav UI
        document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
        el.classList.add('active');
    }

    async function invest(city, cost) {
        const res = await fetch('/invest', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ city, cost, user_id: '<%= user.id %>' })
        });
        const data = await res.json();
        alert(data.message);
        if(data.success) location.reload();
    }

    async function claimTask() {
        const res = await fetch('/claim_task', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ user_id: '<%= user.id %>' })
        });
        const data = await res.json();
        alert(data.message);
        if(data.success) location.reload();
    }
</script>

</body>
</html>
