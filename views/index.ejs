<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BITREX Platform</title>
  <style>
    :root{--bg:#080f1f;--bg2:#0b1730;--card:#121d33cc;--line:#2f3e5d;--text:#e8eeff;--muted:#a8b5d8;--blue:#4f8dff;--cyan:#35d3ff;--green:#22c55e;--red:#ef4444}
    *{box-sizing:border-box}
    body{margin:0;background:radial-gradient(1200px 600px at 20% -10%,#1f4ccf66,transparent),radial-gradient(900px 500px at 120% 20%,#0ea5e966,transparent),linear-gradient(180deg,var(--bg),var(--bg2));font-family:Inter,system-ui,Arial,sans-serif;color:var(--text)}
    .container{max-width:980px;margin:0 auto;padding:18px 16px 96px}
    .card{background:var(--card);backdrop-filter:blur(8px);border:1px solid var(--line);border-radius:18px;padding:16px;margin-bottom:14px;box-shadow:0 10px 30px #00000055}
    .hero{display:flex;justify-content:space-between;align-items:center;gap:12px;background:linear-gradient(120deg,#2c65f8,#00b8f0)}
    .hero h2{margin:0;font-size:1.45rem}
    h3{margin:0 0 10px} .small{color:var(--muted);font-size:.93rem}
    .msg{padding:11px 12px;border-radius:10px;margin-bottom:12px}.ok{background:#062d19;color:#a7f3d0}.err{background:#3a0f14;color:#fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:center;gap:10px}
    .pill-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .pill{background:linear-gradient(180deg,#0f1a31,#0c162b);border:1px solid #304268;border-radius:14px;padding:10px}
    .kpi{font-size:1.2rem;font-weight:700}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    input,select,button{width:100%;padding:11px 12px;border-radius:12px;border:1px solid #304268;background:#0a1428;color:var(--text);margin:6px 0}
    input:focus,select:focus{outline:none;border-color:#5ea2ff;box-shadow:0 0 0 3px #3b82f633}
    button{border:none;background:linear-gradient(120deg,var(--blue),var(--cyan));font-weight:700;cursor:pointer;transition:.2s transform}
    button:hover{transform:translateY(-1px)}
    .btn-red{background:linear-gradient(120deg,#b91c1c,#ef4444)}
    .badge-link{display:inline-flex;align-items:center;gap:6px;padding:7px 11px;border:1px solid #6cc2ff;border-radius:999px;background:#0a3158;color:#d8f1ff;text-decoration:none;font-size:.82rem}
    table{width:100%;border-collapse:collapse}
    th,td{padding:9px 8px;border-bottom:1px solid #253654;font-size:.9rem;text-align:left}
    th{color:#c7d8ff;font-weight:600}
    .section{display:none}.section.active{display:block}
    .status{padding:2px 8px;border-radius:999px;font-size:.75rem;font-weight:700;display:inline-block}.PENDING{background:#78350f;color:#fde68a}.APPROVED{background:#14532d;color:#bbf7d0}.REJECTED{background:#7f1d1d;color:#fecaca}
    .bottom-nav{position:fixed;left:50%;transform:translateX(-50%);bottom:10px;width:min(960px,calc(100% - 16px));background:#0a1326cc;backdrop-filter:blur(8px);border:1px solid #2c3e63;border-radius:14px;display:grid;grid-template-columns:repeat(4,1fr);overflow:hidden;z-index:10}
    .bottom-nav button{margin:0;border-radius:0;background:transparent;border-right:1px solid #243654;padding:10px;color:#d8e6ff}
    .bottom-nav button:last-child{border-right:none}
    .copy-actions{display:flex;gap:8px;flex-wrap:wrap}
    .copy-actions button{width:auto;padding:6px 10px;border-radius:999px}
    @media(max-width:820px){.pill-grid,.row{grid-template-columns:1fr}.hero{flex-direction:column;align-items:flex-start}}
  </style>
</head>
<body>
  <div class="container">
    <% if (error) { %><div class="msg err"><%= error %></div><% } %>
    <% if (message) { %><div class="msg ok"><%= message %></div><% } %>

    <% if (!user) { %>
      <div class="card hero">
        <div>
          <h2>Welcome to BITREX Business Platform</h2>
          <div class="small" style="color:#ecfeff">Create account, join cities, complete daily tasks and grow your earnings dashboard.</div>
        </div>
        <a href="/admin" class="badge-link">⚙️ Admin Portal</a>
      </div>
      <div class="row">
        <div class="card">
          <h3>Create Account</h3>
          <form method="post" action="/signup">
            <input name="phone" placeholder="Phone Number" required />
            <input name="email" type="email" placeholder="Email Address" required />
            <input name="password" type="password" minlength="6" maxlength="8" placeholder="Password (6-8 chars)" required />
            <input name="referralCode" placeholder="Referral Code (Optional)" value="<%= referralFromQuery || '' %>" />
            <button type="submit">Sign Up</button>
          </form>
        </div>
        <div class="card">
          <h3>Login</h3>
          <form method="post" action="/login">
            <input name="phone" placeholder="Phone Number" required />
            <input name="password" type="password" placeholder="Password" required />
            <button type="submit">Log In</button>
          </form>
        </div>
      </div>
    <% } else { %>
      <div class="card topbar">
        <div>
          <h3>BITREX Dashboard</h3>
          <div class="small">Registered Number: <strong><%= user.phone %></strong></div>
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <a href="/admin" class="badge-link">⚙️ Admin Portal</a>
          <form action="/logout" method="post"><button class="btn-red" style="width:auto;padding:10px 14px;">Logout</button></form>
        </div>
      </div>

      <section id="home" class="section active">
        <div class="card pill-grid">
          <div class="pill"><div class="small">Balance</div><div class="kpi">KSH <%= user.balance %></div></div>
          <div class="pill"><div class="small">Today's Income</div><div class="kpi">KSH <%= user.todayIncome %></div></div>
          <div class="pill"><div class="small">Total Earnings</div><div class="kpi">KSH <%= user.totalEarnings %></div></div>
        </div>

        <div class="card">
          <h3>Active Investments</h3>
          <% if (!user.activeCities.length) { %><p class="small">No city joined yet.</p><% } else { %>
          <table>
            <thead><tr><th>City</th><th>Days</th><th>Daily Income</th></tr></thead>
            <tbody>
              <% user.activeCities.forEach(code => { %>
                <tr>
                  <td><%= cityConfig[code].city %></td>
                  <td>
                    <%= Math.floor((Date.now()-new Date(user.cityJoinDates[code]).getTime())/(1000*60*60*24))+1 %>
                    <% if (code === 'INTERN') { %>
                      / 4
                      <% if (internExpired) { %><span class="status REJECTED">EXPIRED</span><% } %>
                    <% } %>
                  </td>
                  <td>KSH <%= code === 'INTERN' && internExpired ? 0 : cityConfig[code].dailyIncome %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>

        <div class="row">
          <div class="card">
            <h3>Deposit (Min KSH 300)</h3>
            <p class="small">Send money to <strong>0733319700</strong>. Reflects after admin approval.</p>
            <form action="/deposit" method="post" enctype="multipart/form-data">
              <input name="phone" placeholder="Your Phone Number" required />
              <input name="amount" type="number" min="300" placeholder="Amount" required />
              <input type="file" name="evidence" />
              <button type="submit">Submit Deposit</button>
            </form>
          </div>
          <div class="card">
            <h3>Withdraw (Min KSH 500)</h3>
            <form action="/withdraw" method="post">
              <input name="phone" placeholder="Phone to Receive Payment" required />
              <input name="amount" type="number" min="500" placeholder="Amount" required />
              <input name="withdrawalPassword" type="password" placeholder="Withdrawal Password" required />
              <button type="submit">Withdraw</button>
            </form>
          </div>
        </div>
      </section>

      <section id="task" class="section">
        <div class="card">
          <h3>Daily Tasks (KSH 50 each)</h3>
          <p class="small">Tasks reset after midnight and are limited by active city packages.</p>
          <form method="post" action="/task">
            <select name="taskName" required>
              <option value="">Select task</option>
              <% tasks.forEach(t => { %><option value="<%= t %>"><%= t %> - KSH 50</option><% }) %>
            </select>
            <button type="submit">Complete Task</button>
          </form>
          <p class="small">Tasks completed today: <%= user.tasksCompletedToday %> / <%= taskLimitToday %></p>
        </div>
      </section>

      <section id="city" class="section">
        <div class="card">
          <h3>City Investments</h3>
          <table>
            <thead><tr><th>City</th><th>Amount</th><th>Task/day</th><th>Daily Income</th><th></th></tr></thead>
            <tbody>
              <% Object.keys(cityConfig).forEach(code => { const c=cityConfig[code]; %>
                <tr>
                  <td><%= c.city %></td><td>KSH <%= c.amount %></td><td><%= c.tasksPerDay %></td><td>KSH <%= c.dailyIncome %></td>
                  <td><form method="post" action="/invest/<%= code %>"><button type="submit">Join</button></form></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section id="menu" class="section">
        <div class="card">
          <h3>Menu</h3>
          <p>Manager WhatsApp: <a href="https://wa.me/254780535898" target="_blank" class="badge-link">0780535898</a></p>
          <p>Your Referral Code: <strong><%= user.referralCode %></strong></p>
          <p>Referrals: <%= user.referredCount %> / 5 friends (bonus KSH 300 one-time).</p>
          <div class="copy-actions">
            <a href="<%= referralLink %>" target="_blank" class="badge-link">Open Referral Link</a>
            <button type="button" onclick="copyReferral('<%= referralLink %>')">Copy</button>
            <button type="button" onclick="shareReferral('<%= referralLink %>')">Share</button>
          </div>
        </div>

        <div class="card">
          <h3>User Profile</h3>
          <input value="<%= user.phone %>" readonly />
          <input value="<%= user.email %>" readonly />
          <form action="/profile/password" method="post">
            <input type="password" name="currentPassword" placeholder="Current password" required />
            <input type="password" name="newPassword" minlength="6" maxlength="8" placeholder="New password (6-8 characters)" required />
            <button type="submit">Update Password</button>
          </form>
        </div>

        <div class="card">
          <h3>Transaction History</h3>
          <% if (!user.transactions.length) { %><p class="small">No transactions yet.</p><% } %>
          <table>
            <thead><tr><th>Type</th><th>Amount</th><th>Status</th><th>Detail</th><th>Date</th></tr></thead>
            <tbody>
              <% user.transactions.slice(0,20).forEach(tx => { %>
                <tr>
                  <td><%= tx.type %></td>
                  <td>KSH <%= tx.amount %></td>
                  <td><span class="status <%= tx.status || 'APPROVED' %>"><%= tx.status || 'APPROVED' %></span></td>
                  <td><%= tx.detail %></td>
                  <td><%= new Date(tx.date).toLocaleString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <nav class="bottom-nav">
        <button onclick="switchTab('home')">🏠 Home</button>
        <button onclick="switchTab('task')">✅ Task</button>
        <button onclick="switchTab('city')">🏙️ City</button>
        <button onclick="switchTab('menu')">☰ Menu</button>
      </nav>
      <script>
        function switchTab(id){
          document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
          document.getElementById(id).classList.add('active');
        }
        function copyReferral(link){
          navigator.clipboard.writeText(link).then(()=>alert('Referral link copied'));
        }
        async function shareReferral(link){
          if (navigator.share){
            await navigator.share({title:'Join BITREX', text:'Use my referral link', url:link});
          } else {
            copyReferral(link);
          }
        }
      </script>
    <% } %>
  </div>
</body>
</html>
