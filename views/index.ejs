<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX | Dashboard</title>
    <style>
        :root { --primary: #2b7fff; --bg: #f0f4f7; }
        body { font-family: sans-serif; background: var(--bg); margin: 0; padding-bottom: 80px; }
        .hidden { display: none !important; }
        
        /* Fixed Header */
        .header { background: var(--primary); color: white; padding: 40px 20px 70px; text-align: center; border-radius: 0 0 35px 35px; position: relative; }
        .user-number { position: absolute; top: 15px; right: 20px; font-weight: bold; font-size: 14px; }
        .balance-box { font-size: 40px; font-weight: 800; margin: 10px 0; }
        
        .action-container { display: flex; gap: 10px; margin: -40px 15px 20px; position: relative; z-index: 10; }
        .action-btn { background: white; flex: 1; padding: 15px; border-radius: 15px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.1); cursor: pointer; }

        /* Job UI */
        .job-title-bar { background: #c5ff8c; padding: 15px; text-align: center; font-weight: bold; border-radius: 15px 15px 0 0; }
        .job-card { background: white; margin: 10px; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }

        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center; }
        .nav { position: fixed; bottom: 0; width: 100%; background: white; display: flex; padding: 10px 0; border-top: 1px solid #eee; }
        .nav-item { flex: 1; text-align: center; font-size: 11px; color: #888; cursor: pointer; }
        .nav-item.active { color: var(--primary); font-weight: bold; }
    </style>
</head>
<body>

    <div class="header">
        <div class="user-number"><%= user.phone %></div>
        <div style="font-size: 14px; opacity: 0.9;">Account balance</div>
        <div class="balance-box">Ksh <%= user.balance %></div>
        <div style="display: flex; justify-content: space-around; margin-top: 20px;">
            <div><small>Today's Income</small><br><b><%= user.todays_income || 0 %></b></div>
            <div><small>Total Income</small><br><b><%= user.total_income || 0 %></b></div>
        </div>
    </div>

    <div class="action-container">
        <div class="action-btn" onclick="toggleModal('deposit', true)"><span>💳 Top-up</span></div>
        <div class="action-btn" onclick="toggleModal('withdraw', true)"><span>📥 Withdraw</span></div>
        <div class="action-btn" onclick="showSec('menu', document.getElementById('menu-nav'))"><span>👤 Profile</span></div>
    </div>

    <div id="home-sec">
        <div style="margin: 15px; font-weight: bold;">Active Cities</div>
        <div class="job-card">
            <% if (userCities.length > 0) { %>
                <% userCities.forEach(city => { %>
                    <div style="padding: 10px 0; border-bottom: 1px solid #eee;">🏙️ <b><%= city.city_name %></b> - Active</div>
                <% }); %>
            <% } else { %> <p style="text-align: center; color: #999;">No active cities.</p> <% } %>
        </div>
    </div>

    <div id="task-sec" class="hidden">
        <div class="job-title-bar">List of jobs</div>
        <% const jobs = ["AQ Smart Blood Glucose Meter", "Manicure Set", "women's perfume", "Mini massage gun", "2.5L Vacuum Flask", "Electric blender", "Modern soldering gun", "Smart phones", "HD Camera", "Laptops"]; %>
        <% jobs.forEach(job => { %>
            <div class="job-card">
                <b><%= job %></b><p>Reward: Ksh 50</p>
                <button onclick="doTask()" style="background:black; color:white; width:100%; padding:10px; border:none; border-radius:5px;">Start working</button>
            </div>
        <% }); %>
    </div>

    <div id="city-sec" class="hidden">
        <div style="margin: 15px; font-weight: bold;">Join a City</div>
        <% const cityData = [{n:'CITY A', c:1500}, {n:'CITY B', c:3200}, {n:'CITY C', c:7200}, {n:'CITY D', c:12000}, {n:'CITY E', c:15000}]; %>
        <% cityData.forEach(c => { %>
            <div class="job-card" style="display:flex; justify-content:space-between; align-items:center;">
                <div><b><%= c.n %></b><br><small>Ksh <%= c.c %></small></div>
                <button onclick="joinCity('<%= c.n %>')" style="background:var(--primary); color:white; padding:8px 15px; border:none; border-radius:5px;">Join</button>
            </div>
        <% }); %>
    </div>

    <div id="menu-sec" class="hidden">
        <div class="job-card">
            <p><b>Phone:</b> <%= user.phone %></p>
            <p><b>Referral:</b> <%= user.referral_code %></p>
            <button onclick="location.href='/logout'" style="background:#ff4d4d; color:white; width:100%; padding:10px; border:none; border-radius:5px;">Log Out</button>
        </div>
    </div>

    <div id="deposit-modal" class="overlay hidden">
        <div style="background:white; padding:20px; border-radius:15px; width:85%;">
            <h3>Top-up</h3><p>Send to: 0733319700</p>
            <input type="number" id="dep-amt" placeholder="Amount" style="width:100%; padding:10px; margin-bottom:10px;">
            <button onclick="toggleModal('deposit', false)" style="width:100%; padding:10px;">Close</button>
        </div>
    </div>

    <div id="withdraw-modal" class="overlay hidden">
        <div style="background:white; padding:20px; border-radius:15px; width:85%;">
            <h3>Withdraw</h3>
            <input type="number" id="wit-amt" placeholder="Amount" style="width:100%; padding:10px; margin-bottom:10px;">
            <button onclick="submitWit()" style="background:var(--primary); color:white; width:100%; padding:10px; border:none; border-radius:5px;">Submit</button>
            <button onclick="toggleModal('withdraw', false)" style="width:100%; padding:10px; border:none; background:none;">Cancel</button>
        </div>
    </div>

    <div class="nav">
        <div class="nav-item active" onclick="showSec('home', this)">🏠<br>Home</div>
        <div class="nav-item" onclick="showSec('task', this)">⚡<br>Task</div>
        <div class="nav-item" onclick="showSec('city', this)">🏙️<br>City</div>
        <div id="menu-nav" class="nav-item" onclick="showSec('menu', this)">👤<br>Menu</div>
    </div>

    <script>
        function showSec(id, el) {
            ['home', 'task', 'city', 'menu'].forEach(s => document.getElementById(s + '-sec').classList.add('hidden'));
            document.getElementById(id + '-sec').classList.remove('hidden');
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            el.classList.add('active');
        }
        function toggleModal(type, show) {
            document.getElementById(type + '-modal').classList[show ? 'remove' : 'add']('hidden');
        }
        async function joinCity(name) {
            const res = await fetch('/invest', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ city_name: name, user_id: '<%= user.id %>' }) });
            const data = await res.json(); alert(data.message); if(data.success) location.reload();
        }
        async function doTask() {
            const res = await fetch('/claim_task', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ user_id: '<%= user.id %>' }) });
            const data = await res.json(); alert(data.message); if(data.success) location.reload();
        }
        async function submitWit() {
            const amount = document.getElementById('wit-amt').value;
            const res = await fetch('/withdraw', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ amount, user_id: '<%= user.id %>' }) });
            const data = await res.json(); alert(data.message); if(data.success) location.reload();
        }
    </script>
</body>
</html>
