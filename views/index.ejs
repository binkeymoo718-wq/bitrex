<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Business Platform</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background: #f4f7f6; padding-bottom: 70px; }
        .card { border-radius: 15px; border: none; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
        .nav-bottom { position: fixed; bottom: 0; width: 100%; background: #fff; display: flex; justify-content: space-around; padding: 10px 0; border-top: 1px solid #ddd; }
        .nav-item { text-align: center; color: #666; text-decoration: none; font-size: 12px; }
        .nav-item.active { color: #007bff; }
        .header { background: linear-gradient(135deg, #007bff, #00c6ff); color: white; padding: 20px; border-radius: 0 0 25px 25px; }
        .city-card { margin-bottom: 15px; border-left: 5px solid #007bff; }
        .task-item { display: flex; justify-content: space-between; align-items: center; padding: 15px; background: white; margin-bottom: 10px; border-radius: 10px; }
        .hidden { display: none; }
    </style>
</head>
<body>

    <!-- Top Header -->
    <div class="header d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0">Welcome</h5>
            <small>Manage your investments</small>
        </div>
        <div class="text-end">
            <span class="badge bg-light text-dark"><%= user.phone %></span>
        </div>
    </div>

    <div class="container mt-3">
        
        <!-- HOME SECTION -->
        <div id="home-section" class="tab-content">
            <div class="card p-3 mb-3 bg-white text-center">
                <small class="text-muted">Current Balance</small>
                <h2 class="text-primary">Ksh <%= user.balance.toFixed(2) %></h2>
                <div class="row mt-2">
                    <div class="col-6 border-end">
                        <small>Today's Income</small><br><strong>Ksh <%= user.dailyIncome %></strong>
                    </div>
                    <div class="col-6">
                        <small>Total Earnings</small><br><strong>Ksh <%= user.totalEarnings %></strong>
                    </div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-success btn-sm" onclick="showDeposit()">Deposit</button>
                    <button class="btn btn-outline-primary btn-sm" onclick="showWithdraw()">Withdraw</button>
                </div>
            </div>

            <h6>Active Investments</h6>
            <% if(user.investments.length == 0) { %>
                <p class="text-muted">No active cities. Visit City tab to invest.</p>
            <% } else { %>
                <% user.investments.forEach(inv => { %>
                    <div class="card p-2 mb-2">
                        <div class="d-flex justify-content-between">
                            <strong><%= inv.cityName %></strong>
                            <span class="text-success">Active</span>
                        </div>
                        <small>Joined: <%= inv.dateJoined %></small>
                    </div>
                <% }) %>
            <% } %>
        </div>

        <!-- TASK SECTION -->
        <div id="task-section" class="tab-content hidden">
            <h5 class="mb-3">Daily Tasks (<%= user.tasksDoneToday %> / <%= maxTasks %>)</h5>
            <div id="taskList">
                <!-- Task items -->
                <% let items = ['2.5L Vacuum Flask', 'Mini massage gun', 'Electric blender', 'Smart phones', 'Laptops', 'Air Fryer']; %>
                <% items.forEach(item => { %>
                    <div class="task-item">
                        <div>
                            <strong><%= item %></strong><br>
                            <small class="text-muted">Shipment to City</small>
                        </div>
                        <button class="btn btn-primary btn-sm" onclick="completeTask()">Complete (Ksh 50)</button>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- CITY SECTION -->
        <div id="city-section" class="tab-content hidden">
            <h5 class="mb-3">City Investments</h5>
            <% Object.keys(cities).forEach(key => { %>
                <div class="card p-3 mb-2 city-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5><%= key %></h5>
                            <small>Price: Ksh <%= cities[key].price %></small><br>
                            <small>Daily: <%= cities[key].dailyTasks %> Task(s) | Ksh <%= cities[key].dailyIncome %></small>
                        </div>
                        <button class="btn btn-dark" onclick="invest('<%= key %>')">Invest</button>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- MENU SECTION -->
        <div id="menu-section" class="tab-content hidden">
            <ul class="list-group">
                <li class="list-group-item"><i class="bi bi-person"></i> Referral Code: <strong><%= user.myReferralCode %></strong></li>
                <li class="list-group-item"><i class="bi bi-whatsapp"></i> <a href="https://wa.me/254106305272">Contact Manager</a></li>
                <li class="list-group-item" onclick="alert('Transaction history shown here')">Transaction History</li>
                <li class="list-group-item text-danger" onclick="window.location.href='/login'">Logout</li>
            </ul>
        </div>

    </div>

    <!-- Bottom Nav -->
    <nav class="nav-bottom">
        <a href="javascript:void(0)" onclick="switchTab('home')" class="nav-item active" id="nav-home">
            <i class="bi bi-house-door d-block fs-4"></i>Home
        </a>
        <a href="javascript:void(0)" onclick="switchTab('task')" class="nav-item" id="nav-task">
            <i class="bi bi-list-check d-block fs-4"></i>Tasks
        </a>
        <a href="javascript:void(0)" onclick="switchTab('city')" class="nav-item" id="nav-city">
            <i class="bi bi-building d-block fs-4"></i>Cities
        </a>
        <a href="javascript:void(0)" onclick="switchTab('menu')" class="nav-item" id="nav-menu">
            <i class="bi bi-grid d-block fs-4"></i>Menu
        </a>
    </nav>

    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
            document.getElementById(tab + '-section').classList.remove('hidden');
            document.getElementById('nav-' + tab).classList.add('active');
        }

        async function completeTask() {
            const res = await fetch('/do-task', { method: 'POST' });
            const data = await res.json();
            if(data.success) {
                alert('Task completed successfully!');
                location.reload();
            } else {
                alert(data.message);
            }
        }

        async function invest(cityName) {
            if(!confirm('Confirm investment in ' + cityName)) return;
            const res = await fetch('/invest', { 
                method: 'POST', 
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'cityName=' + cityName
            });
            const data = await res.json();
            if(data.success) {
                alert('Welcome to ' + cityName);
                location.reload();
            } else {
                alert(data.message);
            }
        }

        function showDeposit() {
            let amt = prompt("Enter amount to deposit (Min 300):\nPay to 0733319700");
            if(amt) {
                // In a real app, send to server to wait for verification
                location.reload();
            }
        }

        function showWithdraw() {
            let amt = prompt("Enter amount to withdraw (Min 500):");
            if(amt < 500) alert("Minimum withdrawal is 500");
            else alert("Withdrawal request sent!");
        }
    </script>
</body>
</html>
