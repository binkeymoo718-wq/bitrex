<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX | Dashboard</title>
    <style>
        :root { --primary-blue: #2b7fff; --bg: #f0f4f7; }
        body { font-family: sans-serif; background: var(--bg); margin: 0; padding-bottom: 80px; }
        
        /* Dashboard Header */
        .header { background: var(--primary-blue); color: white; padding: 40px 20px 70px; text-align: center; border-radius: 0 0 35px 35px; position: relative; }
        .user-phone { position: absolute; top: 15px; right: 20px; font-size: 14px; font-weight: bold; }
        .balance-box { font-size: 40px; font-weight: 800; margin: 10px 0; }
        
        .stats-row { display: flex; justify-content: space-around; background: rgba(255,255,255,0.15); padding: 15px; border-radius: 15px; margin-top: 20px; }
        .stat-box div:first-child { font-size: 11px; opacity: 0.8; }
        .stat-box div:last-child { font-size: 16px; font-weight: bold; }

        /* Action Buttons */
        .action-container { display: flex; gap: 10px; margin: -40px 15px 20px; }
        .action-btn { background: white; flex: 1; padding: 15px; border-radius: 15px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.1); cursor: pointer; }
        .action-btn span { font-size: 11px; font-weight: bold; color: #444; }

        /* Sections */
        .card { background: white; margin: 10px 15px; padding: 15px; border-radius: 15px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .hidden { display: none; }
        .btn { border: none; border-radius: 10px; padding: 12px; width: 100%; cursor: pointer; font-weight: bold; }
        
        /* Job List UI */
        .job-title-bar { background: #c5ff8c; padding: 15px; text-align: center; font-weight: bold; border-radius: 15px 15px 0 0; }
        .job-card { border-bottom: 1px dashed #eee; padding: 15px 0; }
        .job-card h4 { margin: 0 0 5px; color: #1a3c61; }
        .job-card p { font-size: 11px; color: #888; margin: 0; }

        /* Modal Overlay */
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 1000; display: flex; align-items: center; justify-content: center; }

        /* Bottom Nav */
        .nav { position: fixed; bottom: 0; width: 100%; background: white; display: flex; padding: 10px 0; border-top: 1px solid #eee; }
        .nav-item { flex: 1; text-align: center; font-size: 11px; color: #888; cursor: pointer; }
        .nav-item.active { color: var(--primary-blue); font-weight: bold; }
    </style>
</head>
<body>

    <div class="header">
        <div class="user-phone"><%= user.phone %></div>
        <div style="font-size: 14px; opacity: 0.9;">Account balance</div>
        <div class="balance-box"><%= user.balance %></div>
        
        <div class="stats-row">
            <div class="stat-box"><div>Today</div><div><%= user.todays_income || 0 %></div></div>
            <div class="stat-box"><div>Month</div><div><%= user.monthly_income || 0 %></div></div>
            <div class="stat-box"><div>Total</div><div><%= user.total_income || 0 %></div></div>
        </div>
    </div>

    <div class="action-container">
        <div class="action-btn" onclick="openModal('deposit')"><span>💳 Top-up</span></div>
        <div class="action-btn" onclick="openModal('withdraw')"><span>📥 Withdraw</span></div>
        <div class="action-btn" onclick="showSec('menu', this)"><span>👤 Profile</span></div>
    </div>

    <div id="home-sec">
        <div style="margin: 15px; font-weight: bold;">My Active Cities</div>
        <div class="card">
            <% if (userCities.length > 0) { %>
                <% userCities.forEach(city => { %>
                    <div style="padding: 10px 0; border-bottom: 1px solid #eee;">🏙️ <b><%= city.city_name %></b> - Active</div>
                <% }); %>
            <% } else { %>
                <p style="text-align: center; color: #999;">Join a city to start earning.</p>
            <% } %>
        </div>
    </div>

    <div id="task-sec" class="hidden">
        <div class="card" style="padding: 0;">
            <div class="job-title-bar">List of jobs</div>
            <div style="padding: 15px;">
                <% const jobs = ["AQ Smart Blood Glucose Meter", "Manicure Set", "women's perfume", "Mini massage gun", "2.5L Vacuum Flask", "Electric blender", "Modern soldering gun", "Television set", "Electric meter", "Smart phones", "HD Camera", "Iron sheets", "Plumbing tools", "Furniture", "Wi-Fi systems", "Laptops", "Textiles", "Paints", "Cosmetics", "Electrical tools", "Shoes", "Gas cookers", "Electric heater", "Air Fryer", "Pressure Cooker", "Microwave Oven", "Non-stick Cookware", "Water Dispenser", "Juicer Cup", "Electric Kettle", "Subwoofer", "Android TV Box", "Bluetooth Speaker", "Gaming Console", "Smart Watch", "Wireless Earbuds", "Solar Lighting"]; %>
                <% jobs.forEach(job => { %>
                    <div class="job-card">
                        <h4><%= job %></h4>
                        <p>Start working after midnight. Reward: Ksh 50</p>
                        <button class="btn" style="background: black; color: white; margin-top: 10px;" onclick="doTask()">Start working</button>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>

    <div id="city-sec" class="hidden">
        <div style="margin: 15px; font-weight: bold;">Investment Packages</div>
        <% const cityData = [{n:'CITY A', c:1500, d:50}, {n:'CITY B', c:3200, d:100}, {n:'CITY C', c:7200, d:200}, {n:'CITY D', c:12000, d:400}, {n:'CITY E', c:15000, d:500}]; %>
        <% cityData.forEach(c => { %>
            <div class="card" style="display: flex; justify-content: space-between; align-items: center;">
                <div><b><%= c.n %></b><br><small>Cost: Ksh <%= c.c %> | Daily: Ksh <%= c.d %></small></div>
                <button class="btn" style="width: 80px; background: var(--primary-blue); color: white;" onclick="joinCity('<%= c.n %>')">Join</button>
            </div>
        <% }); %>
    </div>

    <div id="menu-sec" class="hidden">
        <div class="card">
            <p><b>Referral Code:</b> <%= user.referral_code %></p>
            <button class="btn" style="background: #25d366; color: white; margin-bottom: 10px;" onclick="window.open('https://wa.me/254106305272')">WhatsApp Manager</button>
            <button class="btn" style="background: #eee;" onclick="location.href='/logout'">Log Out</button>
        </div>
    </div>

    <div id="modal-overlay" class="overlay hidden">
        <div class="card" id="deposit-box" class="hidden" style="width: 80%;">
            <h3>Top-up</h3>
            <p>Send to 0733319700</p>
            <input type="number" id="dep-amt" placeholder="Amount" class="btn" style="border: 1px solid #ddd; margin-bottom: 10px;">
            <input type="text" id="dep-ev" placeholder="M-PESA Code" class="btn" style="border: 1px solid #ddd; margin-bottom: 10px;">
            <button class="btn" style="background: var(--primary-blue); color: white;" onclick="submitDep()">Submit</button>
            <button class="btn" style="margin-top: 5px;" onclick="closeModal()">Close</button>
        </div>
    </div>

    <div class="nav">
        <div class="nav-item active" onclick="showSec('home', this)">🏠<br>Home</div>
        <div class="nav-item" onclick="showSec('task', this)">⚡<br>Task</div>
        <div class="nav-item" onclick="showSec('city', this)">🏙️<br>City</div>
        <div class="nav-item" onclick="showSec('menu', this)">👤<br>Menu</div>
    </div>

    <script>
        function showSec(id, el) {
            ['home', 'task', 'city', 'menu'].forEach(s => document.getElementById(s + '-sec').classList.add('hidden'));
            document.getElementById(id + '-sec').classList.remove('hidden');
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            el.classList.add('active');
        }

        async function joinCity(name) {
            if(!confirm("Join " + name + "?")) return;
            const res = await fetch('/invest', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ city_name: name, user_id: '<%= user.id %>' }) });
            const data = await res.json();
            alert(data.message);
            if(data.success) location.reload();
        }

        function openModal(type) { 
            document.getElementById('modal-overlay').classList.remove('hidden'); 
        }
        function closeModal() { 
            document.getElementById('modal-overlay').classList.add('hidden'); 
        }

        async function doTask() {
            const res = await fetch('/claim_task', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ user_id: '<%= user.id %>' }) });
            const data = await res.json();
            alert(data.message);
            if(data.success) location.reload();
        }
    </script>
</body>
</html>
