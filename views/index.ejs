<!DOCTYPE html>
<html>
<head>
<title>BITREX</title>
<style>
body { font-family: Arial; margin:0; background:#f5f5f5; }
.header { padding:15px; background:#635BFF; color:white; display:flex; justify-content:space-between;}
.card { margin:15px; padding:20px; background:white; border-radius:10px;}
button { padding:10px; border:none; background:#635BFF; color:white; border-radius:5px;}
.bottom { position:fixed; bottom:0; width:100%; background:white; display:flex; justify-content:space-around; padding:10px;}
</style>
</head>

<body>

<% if (!user) { %>

<div style="padding:40px;">
<h2>BITREX</h2>
<input id="phone" placeholder="Phone"><br><br>
<input id="pass" type="password" placeholder="Password"><br><br>
<button onclick="login()">Login</button>
</div>

<% } else { %>

<div class="header">
<span>BITREX</span>
<span><%= user.phone %></span>
</div>

<div class="card">
<h3>Balance: Ksh <%= user.balance %></h3>
<button onclick="deposit()">Deposit</button>
<button onclick="withdraw()">Withdraw</button>
</div>

<div class="card">
<h3>Invest</h3>
<button onclick="invest('CITY A',1500)">CITY A</button>
<button onclick="invest('CITY B',3200)">CITY B</button>
<button onclick="invest('CITY C',7200)">CITY C</button>
<button onclick="invest('CITY D',12000)">CITY D</button>
<button onclick="invest('CITY E',15000)">CITY E</button>
</div>

<div class="card">
<h3>Tasks</h3>
<button onclick="task()">Do Task (+50)</button>
</div>

<div class="bottom">
<div>🏠</div>
<div onclick="task()">⚡</div>
<div>📊</div>
<div>👤</div>
</div>

<% } %>

<script>
let userId = localStorage.getItem("userId");

async function login(){
 const res = await fetch('/auth/login',{
  method:'POST',
  headers:{'Content-Type':'application/json'},
  body:JSON.stringify({
   phone:document.getElementById('phone').value,
   password:document.getElementById('pass').value
  })
 });
 const data = await res.json();
 if(data.success){
  localStorage.setItem("userId", data.user.id);
  location.reload();
 } else alert(data.message);
}

async function invest(city,cost){
 await fetch('/invest',{
  method:'POST',
  headers:{'Content-Type':'application/json'},
  body:JSON.stringify({userId, city, cost})
 });
 alert("Invested");
}

async function task(){
 const res = await fetch('/task',{
  method:'POST',
  headers:{'Content-Type':'application/json'},
  body:JSON.stringify({userId})
 });
 const data = await res.json();
 alert(data.message);
}

async function deposit(){
 const amount = prompt("Enter amount");
 await fetch('/deposit',{
  method:'POST',
  headers:{'Content-Type':'application/json'},
  body:JSON.stringify({userId, amount, evidence:"mpesa"})
 });
 alert("Submitted");
}

async function withdraw(){
 const amount = prompt("Enter amount");
 await fetch('/withdraw',{
  method:'POST',
  headers:{'Content-Type':'application/json'},
  body:JSON.stringify({userId, amount})
 });
 alert("Requested");
}
</script>

</body>
</html>
