<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX Dashboard</title>
    <style>
        body { font-family: sans-serif; background: #f4f7f6; margin: 0; padding-bottom: 70px; }
        .header { background: #1a73e8; color: white; padding: 20px; text-align: center; position: relative; }
        .user-id { position: absolute; top: 10px; right: 10px; font-size: 12px; }
        .card { background: white; margin: 15px; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .btn { width: 100%; padding: 12px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; margin-top: 10px; }
        .btn-deposit { background: #34a853; color: white; }
        .btn-withdraw { background: #ea4335; color: white; }
        .nav-bar { position: fixed; bottom: 0; width: 100%; background: white; display: flex; border-top: 1px solid #ddd; }
        .nav-item { flex: 1; text-align: center; padding: 15px; font-size: 12px; color: #555; cursor: pointer; }
        .nav-item.active { color: #1a73e8; font-weight: bold; }
        .hidden { display: none; }
    </style>
</head>
<body>

<div class="header">
    <div class="user-id">ID: <%= user.phone %></div>
    <h3>Balance Overview</h3>
    <h1 id="balance-display">Ksh <%= user.balance %></h1>
    <div style="display: flex; justify-content: space-around; font-size: 14px;">
        <div>Today: <%= user.todays_income || 0 %></div>
        <div>Total: <%= user.total_income || 0 %></div>
    </div>
</div>

<div id="home-sec">
    <div class="card">
        <h4>Wallet Operations</h4>
        <button class="btn btn-deposit" onclick="showDeposit()">Deposit (Min 300)</button>
        <button class="btn btn-withdraw" onclick="showWithdraw()">Withdraw (Min 500)</button>
    </div>

    <div class="card">
        <h4>Active Status</h4>
        <% if (userCities.length > 0) { %>
            <% userCities.forEach(city => { %>
                <div style="border-bottom: 1px solid #eee; padding: 10px 0;">
                    <b>🏙️ <%= city.city_name %></b> - Days Active: 0
                </div>
            <% }); %>
        <% } else { %>
            <p>No active investments.</p>
        <% } %>
    </div>
</div>

<div id="task-sec" class="hidden">
    <div class="card">
        <h4>Daily Tasks (<%= user.tasks_today || 0 %> Completed)</h4>
        <div style="max-height: 400px; overflow-y: auto;">
            <div onclick="doTask('2.5L Vacuum Flask')" style="padding: 15px; border-bottom: 1px solid #eee;">2.5L Vacuum Flask - Ksh 50</div>
            <div onclick="doTask('Mini Massage Gun')" style="padding: 15px; border-bottom: 1px solid #eee;">Mini Massage Gun - Ksh 50</div>
            <div onclick="doTask('Electric Blender')" style="padding: 15px; border-bottom: 1px solid #eee;">Electric Blender - Ksh 50</div>
            </div>
    </div>
</div>

<div class="nav-bar">
    <div class="nav-item active" onclick="showSec('home')">Home</div>
    <div class="nav-item" onclick="showSec('task')">Tasks</div>
    <div class="nav-item" onclick="location.href='/cities'">Cities</div>
    <div class="nav-item" onclick="location.href='/menu'">Menu</div>
</div>

<script>
    function showSec(name) {
        document.getElementById('home-sec').classList.add('hidden');
        document.getElementById('task-sec').classList.add('hidden');
        document.getElementById(name + '-sec').classList.remove('hidden');
    }

    async function doTask(item) {
        const res = await fetch('/claim_task', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ user_id: '<%= user.id %>' })
        });
        const data = await res.json();
        alert(data.message);
        if(data.success) location.reload();
    }
</script>

</body>
</html>
