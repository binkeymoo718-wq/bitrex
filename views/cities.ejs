<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Investment Cities - BITREX</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f7fa;
            padding: 20px;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px 20px;
            border-radius: 15px;
            margin-bottom: 20px;
            text-align: center;
        }

        .header h1 {
            font-size: 24px;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 14px;
            opacity: 0.9;
        }

        .cities-container {
            display: grid;
            gap: 20px;
        }

        .city-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            border-left: 5px solid #667eea;
            transition: all 0.3s ease;
        }

        .city-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        .city-card.invested {
            border-left-color: #4caf50;
            background: linear-gradient(135deg, #f0f7ff 0%, #fff 100%);
        }

        .city-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .city-name {
            font-size: 24px;
            font-weight: 700;
            color: #333;
        }

        .city-badge {
            background: #4caf50;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .city-details {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }

        .detail-item {
            background: #f9f9f9;
            padding: 12px;
            border-radius: 8px;
            text-align: center;
        }

        .detail-label {
            font-size: 11px;
            color: #888;
            margin-bottom: 5px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .detail-value {
            font-size: 20px;
            font-weight: bold;
            color: #667eea;
        }

        .detail-value.income {
            color: #4caf50;
        }

        .detail-value.tasks {
            color: #ff9800;
        }

        .investment-amount {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
            text-align: center;
        }

        .investment-amount p {
            font-size: 12px;
            opacity: 0.9;
            margin-bottom: 5px;
        }

        .investment-amount .amount {
            font-size: 28px;
            font-weight: bold;
        }

        .btn-invest {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-invest:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-invest:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
        }

        .message {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
            font-weight: 600;
        }

        .message.error {
            background: #ffebee;
            color: #c62828;
            border-left: 4px solid #c62828;
        }

        .message.success {
            background: #e8f5e9;
            color: #2e7d32;
            border-left: 4px solid #2e7d32;
        }

        @media (max-width: 600px) {
            .city-details {
                grid-template-columns: 1fr 1fr;
            }

            .detail-item:nth-child(3) {
                grid-column: 1 / -1;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1><i class="fas fa-city"></i> Investment Cities</h1>
        <p>Choose your city and start earning daily income</p>
    </div>

    <div id="messageContainer"></div>

    <div class="cities-container" id="citiesContainer">
        <p style="text-align: center; color: #888;">Loading cities...</p>
    </div>

    <script>
        const cityData = {
            'CITY A': {
                investment: 1500,
                maxTasks: 1,
                dailyIncome: 50,
                color: '#ff6b6b'
            },
            'CITY B': {
                investment: 3200,
                maxTasks: 2,
                dailyIncome: 100,
                color: '#4ecdc4'
            },
            'CITY C': {
                investment: 7200,
                maxTasks: 4,
                dailyIncome: 200,
                color: '#45b7d1'
            },
            'CITY D': {
                investment: 12000,
                maxTasks: 8,
                dailyIncome: 400,
                color: '#f9ca24'
            },
            'CITY E': {
                investment: 15000,
                maxTasks: 10,
                dailyIncome: 500,
                color: '#6c5ce7'
            }
        };

        async function loadCities() {
            const container = document.getElementById('citiesContainer');
            container.innerHTML = '';

            for (const [cityName, data] of Object.entries(cityData)) {
                const cityCard = document.createElement('div');
                cityCard.className = 'city-card';
                cityCard.innerHTML = `
                    <div class="city-header">
                        <div class="city-name" style="color: ${data.color};">${cityName}</div>
                        <div class="city-badge">Active</div>
                    </div>

                    <div class="investment-amount">
                        <p>Investment Required</p>
                        <div class="amount">KSH ${data.investment.toLocaleString()}</div>
                    </div>

                    <div class="city-details">
                        <div class="detail-item">
                            <div class="detail-label">Daily Income</div>
                            <div class="detail-value income">+KSH ${data.dailyIncome}</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Tasks/Day</div>
                            <div class="detail-value tasks">${data.maxTasks}</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">ROI Period</div>
                            <div class="detail-value">${Math.ceil(data.investment / data.dailyIncome)} days</div>
                        </div>
                    </div>

                    <button class="btn-invest" onclick="investCity('${cityName}')">
                        <i class="fas fa-check"></i> Invest Now
                    </button>
                `;
                container.appendChild(cityCard);
            }
        }

        async function investCity(cityName) {
            try {
                const response = await fetch('/cities/invest', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ city: cityName })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`✓ Successfully invested in ${cityName}! You'll earn KSH ${cityData[cityName].dailyIncome}/day`, 'success');
                    setTimeout(() => {
                        location.reload();
                    }, 2000);
                } else {
                    showMessage(data.message, 'error');
                }
            } catch (error) {
                showMessage('Error investing in city', 'error');
                console.error(error);
            }
        }

        function showMessage(msg, type) {
            const container = document.getElementById('messageContainer');
            container.innerHTML = `<div class="message ${type}">${msg}</div>`;
            setTimeout(() => {
                container.innerHTML = '';
            }, 3000);
        }

        // Load cities on page load
        loadCities();
    </script>
</body>
</html>
