<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX - Sign Up</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen">
    <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-sm">
        <h1 class="text-2xl font-bold text-blue-600 mb-6 text-center">CREATE ACCOUNT</h1>
        <% if(error) { %> <p class="text-red-500 text-sm mb-4"><%= error %></p> <% } %>
        <form action="/signup" method="POST">
            <input type="text" name="phone" placeholder="Phone Number" class="w-full border p-2 mb-4 rounded" required>
            <input type="email" name="email" placeholder="Email Address" class="w-full border p-2 mb-4 rounded" required>
            <input type="password" name="password" placeholder="Password (6-8 chars)" class="w-full border p-2 mb-4 rounded" required>
            <input type="text" name="referralCode" placeholder="Referral Code (Optional)" class="w-full border p-2 mb-4 rounded">
            <button class="w-full bg-blue-600 text-white py-2 rounded font-bold">Register</button>
        </form>
        <p class="text-center mt-4 text-sm">Already have an account? <a href="/" class="text-blue-600">Login</a></p>
    </div>
</body>
</html>
