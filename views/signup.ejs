<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up | Business Platform</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f0f2f5; display: flex; align-items: center; height: 100vh; }
        .auth-card { width: 100%; max-width: 400px; padding: 20px; margin: auto; }
        .btn-primary { background: #007bff; border: none; border-radius: 10px; padding: 12px; }
    </style>
</head>
<body>
    <div class="card auth-card shadow-sm">
        <h3 class="text-center mb-4">Create Account</h3>
        <% if(error) { %> <div class="alert alert-danger"><%= error %></div> <% } %>
        <form action="/signup" method="POST">
            <div class="mb-3">
                <label>Phone Number</label>
                <input type="tel" name="phone" class="form-control" placeholder="e.g. 0712345678" required>
            </div>
            <div class="mb-3">
                <label>Email Address</label>
                <input type="email" name="email" class="form-control" placeholder="name@example.com" required>
            </div>
            <div class="mb-3">
                <label>Password (6-8 characters)</label>
                <input type="password" name="password" class="form-control" minlength="6" maxlength="8" required>
            </div>
            <div class="mb-3">
                <label>Referral Code (Optional)</label>
                <input type="text" name="referralCode" class="form-control" placeholder="Enter code">
            </div>
            <button type="submit" class="btn btn-primary w-100">Sign Up</button>
            <p class="text-center mt-3">Already have an account? <a href="/login">Log In</a></p>
        </form>
    </div>
</body>
</html>
