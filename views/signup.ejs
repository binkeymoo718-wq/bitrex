<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX | Join the Evolution</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #635BFF; --bg: #F8FAFC; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .card { background: white; padding: 40px; border-radius: 24px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); width: 100%; max-width: 380px; text-align: center; }
        h2 { color: var(--primary); font-weight: 800; margin-bottom: 10px; }
        p { color: #64748B; font-size: 0.9rem; margin-bottom: 30px; }
        input { width: 100%; padding: 14px; margin: 8px 0; border: 1px solid #E2E8F0; border-radius: 12px; box-sizing: border-box; font-size: 0.95rem; }
        button { width: 100%; padding: 14px; background: var(--primary); color: white; border: none; border-radius: 12px; font-weight: 700; cursor: pointer; margin-top: 15px; transition: 0.2s; }
        button:hover { opacity: 0.9; transform: translateY(-1px); }
        .footer-link { margin-top: 20px; font-size: 0.85rem; color: #64748B; }
        .footer-link a { color: var(--primary); text-decoration: none; font-weight: 600; }
    </style>
</head>
<body>

    <div class="card">
        <h2>Create Account</h2>
        <p>Start your journey with BITREX</p>
        
        <form action="/signup" method="POST">
            <input type="text" name="name" placeholder="Full Name" required>
            <input type="text" name="phone" placeholder="Phone Number (M-PESA)" required>
            <input type="password" name="password" placeholder="Create Password" required>
            <button type="submit">Get Started</button>
        </form>

        <div class="footer-link">
            Already have an account? <a href="/login">Sign In</a>
        </div>
    </div>

</body>
</html>
