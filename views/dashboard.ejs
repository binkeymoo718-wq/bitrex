<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f7fa;
            padding-bottom: 110px;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .header h1 {
            font-size: 26px;
            letter-spacing: 1px;
        }

        .phone-display {
            background: rgba(255,255,255,0.2);
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 600;
        }

        .content {
            padding: 0 15px;
            max-width: 600px;
            margin: 0 auto;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        }

        .card h3 {
            color: #333;
            margin-bottom: 15px;
            font-size: 18px;
        }

        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 12px;
            text-align: center;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            margin: 10px 0;
        }

        .stat-label {
            font-size: 12px;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .city-item {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 12px;
            border-left: 4px solid #667eea;
        }

        .city-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .city-name {
            font-weight: 700;
            color: #333;
            font-size: 16px;
        }

        .city-days {
            background: #667eea;
            color: white;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
        }

        .city-info {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: #666;
            gap: 10px;
        }

        .investment-grid {
            display: grid;
            gap: 12px;
        }

        .investment-card {
            background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
            border: 2px solid #667eea30;
            border-radius: 12px;
            padding: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .investment-card:hover:not(.invested) {
            border-color: #667eea;
            box-shadow: 0 5px 15px rgba(102,126,234,0.2);
            transform: translateY(-3px);
        }

        .investment-card.invested {
            background: linear-gradient(135deg, #3c315 0%, #1a8a15 100%);
            color: white;
            border-color: #2a7a10;
            cursor: not-allowed;
        }

        .investment-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .investment-name {
            font-weight: 700;
            font-size: 16px;
        }

        .investment-price {
            font-weight: 700;
            color: #667eea;
            font-size: 18px;
        }

        .investment-card.invested .investment-price {
            color: white;
        }

        .investment-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            font-size: 12px;
            margin-bottom: 12px;
        }

        .investment-detail {
            background: white;
            padding: 8px;
            border-radius: 6px;
            text-align: center;
        }

        .investment-card.invested .investment-detail {
            background: rgba(255,255,255,0.2);
            color: white;
        }

        .detail-value {
            font-weight: 700;
            font-size: 14px;
        }

        .detail-label {
            font-size: 10px;
            opacity: 0.8;
            text-transform: uppercase;
        }

        .btn {
            padding: 12px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            width: 100%;
        }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102,126,234,0.3);
        }

        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-secondary {
            background: #f0f0f0;
            color: #667eea;
            border: 1px solid #e0e0e0;
            width: 100%;
        }

        .btn-secondary:hover {
            background: #667eea;
            color: white;
        }

        .task-item {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .task-item:hover:not(.disabled) {
            background: #f0f0f0;
            border-color: #667eea;
            transform: translateX(5px);
        }

        .task-item.disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .task-name {
            font-weight: 600;
            color: #333;
        }

        .task-amount {
            background: #667eea;
            color: white;
            padding: 8px 14px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            color: #333;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input, select {
            width: 100%;
            padding: 12px;
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            font-size: 14px;
            font-family: inherit;
            transition: all 0.3s ease;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
        }

        .transaction-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            background: #f9f9f9;
            border-radius: 10px;
            margin-bottom: 10px;
            border-left: 4px solid #667eea;
        }

        .transaction-item.deposit { border-left-color: #3c3; }
        .transaction-item.withdrawal { border-left-color: #f93; }
        .transaction-item.bonus { border-left-color: #f0f; }
        .transaction-item.task_income { border-left-color: #0af; }

        .transaction-info h4 {
            font-size: 13px;
            color: #333;
            margin-bottom: 3px;
        }

        .transaction-info p {
            font-size: 11px;
            color: #999;
        }

        .transaction-amount {
            font-weight: 700;
            font-size: 15px;
        }

        .transaction-amount.positive { color: #3c3; }
        .transaction-amount.negative { color: #f33; }

        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: white;
            display: flex;
            justify-content: space-around;
            border-top: 1px solid #e0e0e0;
            box-shadow: 0 -5px 15px rgba(0,0,0,0.08);
            z-index: 1000;
            padding: 8px 0;
        }

        .nav-item {
            flex: 1;
            padding: 10px;
            text-align: center;
            cursor: pointer;
            border: none;
            background: none;
            font-size: 22px;
            transition: all 0.2s ease;
            color: #999;
        }

        .nav-item.active {
            color: #667eea;
        }

        .nav-item:active {
            transform: scale(0.9);
        }

        .referral-code {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            margin-bottom: 15px;
        }

        .referral-code p {
            font-size: 12px;
            margin-bottom: 8px;
            opacity: 0.9;
        }

        .referral-code h3 {
            font-size: 22px;
            margin-bottom: 12px;
            letter-spacing: 2px;
            font-family: 'Courier New', monospace;
        }

        .referral-code button {
            background: white;
            color: #667eea;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
        }

        .referral-code button:hover {
            transform: scale(1.05);
        }

        .message {
            background: #efe;
            color: #3c3;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 15px;
            border-left: 4px solid #3c3;
            display: none;
            font-size: 13px;
        }

        .message.show {
            display: block;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message.error {
            background: #fee;
            color: #c33;
            border-left-color: #c33;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 15px;
        }

        .progress-bar {
            background: #e0e0e0;
            height: 8px;
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-fill {
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            height: 100%;
            transition: width 0.3s ease;
        }

        @media (max-width: 500px) {
            .header {
                padding: 15px;
            }

            .content {
                padding: 0 12px;
            }

            .card {
                padding: 15px;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>💰 BITREX</h1>
        <div class="phone-display"><%= user.phone %></div>
    </div>

    <div class="content">
        <!-- HOME TAB -->
        <div id="homeTab" class="tab-content active">
            <div class="stat-card">
                <div class="stat-label">Current Balance</div>
                <div class="stat-value" id="balanceDisplay">KSH 0</div>
            </div>

            <div class="stat-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="stat-label">Today's Income</div>
                <div class="stat-value" id="dailyIncomeDisplay">KSH 0</div>
            </div>

            <div class="stat-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                <div class="stat-label">Total Earnings</div>
                <div class="stat-value" id="totalEarningsDisplay">KSH 0</div>
            </div>

            <div class="card">
                <h3>📍 Active Cities</h3>
                <div id="activeCitiesContainer">
                    <p style="color: #999; text-align: center; padding: 20px; font-size: 13px;">No active cities yet. Invest to get started!</p>
                </div>
            </div>

            <div class="card">
                <h3>💳 Quick Actions</h3>
                <div class="grid-2">
                    <button class="btn btn-primary" onclick="switchTab('depositTab')">💰 Deposit</button>
                    <button class="btn btn-secondary" onclick="switchTab('withdrawTab')">💸 Withdraw</button>
                </div>
            </div>
        </div>

        <!-- TASK TAB -->
        <div id="taskTab" class="tab-content">
            <div class="card">
                <h3>📋 Daily Tasks</h3>
                <p style="color: #999; margin-bottom: 15px; font-size: 13px;">Complete tasks to earn instant income</p>

                <div class="form-group">
                    <label>Select City</label>
                    <select id="taskCitySelect" onchange="loadTasksForCity()">
                        <option value="">Choose a city...</option>
                    </select>
                </div>

                <div id="taskCounter" style="background: #f9f9f9; padding: 15px; border-radius: 10px; text-align: center; margin-bottom: 15px; display: none;">
                    <p style="font-size: 12px; color: #999;">Tasks Completed Today</p>
                    <p style="font-size: 20px; font-weight: 700; color: #667eea;"><span id="tasksCompleted">0</span> / <span id="maxTasks">0</span></p>
                </div>

                <div id="tasksContainer">
                    <p style="color: #999; text-align: center; padding: 20px; font-size: 13px;">Select a city to view available tasks</p>
                </div>
            </div>
        </div>

        <!-- CITY TAB -->
        <div id="cityTab" class="tab-content">
            <div class="card">
                <h3>🏙️ Available Cities</h3>
                <p style="color: #999; margin-bottom: 15px; font-size: 13px;">Invest once per city to start earning</p>
                <div id="citiesContainer" class="investment-grid"></div>
            </div>
        </div>

        <!-- DEPOSIT TAB -->
        <div id="depositTab" class="tab-content">
            <div class="card">
                <h3>💰 Deposit Money</h3>
                <p style="color: #999; margin-bottom: 15px; font-size: 13px;">Minimum deposit: KSH 300</p>

                <div id="depositMessage" class="message"></div>

                <div class="form-group">
                    <label>Amount (KSH)</label>
                    <input type="number" id="depositAmount" placeholder="e.g., 500" min="300">
                </div>

                <div class="form-group">
                    <label>Your Phone Number</label>
                    <input type="tel" id="depositPhone" placeholder="0706123456">
                </div>

                <div style="background: #f9f9f9; padding: 12px; border-radius: 10px; margin-bottom: 15px; font-size: 12px; color: #666;">
                    <p><strong>📤 Send Money To:</strong></p>
                    <p style="font-size: 16px; font-weight: 700; color: #667eea; margin-top: 5px;">0733319700</p>
                    <p style="margin-top: 8px; color: #999;">Send the amount via M-Pesa, then enter the amount above and click Submit.</p>
                </div>

                <button class="btn btn-primary" onclick="submitDeposit()">Submit Deposit</button>
            </div>
        </div>

        <!-- WITHDRAW TAB -->
        <div id="withdrawTab" class="tab-content">
            <div class="card">
                <h3>💸 Withdraw Money</h3>
                <p style="color: #999; margin-bottom: 15px; font-size: 13px;">Minimum withdrawal: KSH 500</p>

                <div id="withdrawMessage" class="message"></div>

                <div class="form-group">
                    <label>Amount (KSH)</label>
                    <input type="number" id="withdrawAmount" placeholder="e.g., 1000" min="500">
                </div>

                <div class="form-group">
                    <label>Phone Number (M-Pesa)</label>
                    <input type="tel" id="withdrawPhone" placeholder="0706123456">
                </div>

                <div class="form-group">
                    <label>Withdrawal Password</label>
                    <input type="password" id="withdrawPassword" placeholder="Your password">
                </div>

                <button class="btn btn-primary" onclick="submitWithdraw()">Withdraw Now</button>
            </div>
        </div>

        <!-- REFERRAL TAB -->
        <div id="referralTab" class="tab-content">
            <div class="card">
                <h3>🎁 Referral Program</h3>
                <p style="color: #999; margin-bottom: 15px; font-size: 13px;">Earn KSH 300 for every 5 friends who join!</p>

                <div class="referral-code">
                    <p>Your Unique Referral Code</p>
                    <h3 id="referralCodeDisplay">LOADING...</h3>
                    <button onclick="copyReferralCode()">📋 Copy Code</button>
                </div>

                <div class="card" style="background: #f9f9f9; padding: 15px;">
                    <p style="font-weight: 600; margin-bottom: 8px;">Referrals: <span id="referralCountDisplay">0</span>/5</p>
                    <div class="progress-bar">
