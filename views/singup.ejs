<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITREX - Sign Up</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-blue-50 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-3xl shadow-xl w-full max-w-sm">
        <h1 class="text-3xl font-black text-center text-blue-700 italic mb-10">BITREX</h1>
        <form action="/signup" method="POST" class="space-y-4">
            <input type="text" name="phone" placeholder="Phone Number" class="w-full p-4 bg-gray-50 border rounded-2xl outline-none" required>
            <input type="email" name="email" placeholder="Email Address" class="w-full p-4 bg-gray-50 border rounded-2xl outline-none" required>
            <input type="password" name="password" placeholder="Password (6-8 chars)" class="w-full p-4 bg-gray-50 border rounded-2xl outline-none" required minlength="6" maxlength="8">
            <input type="text" name="referral" placeholder="Referral Code" class="w-full p-4 bg-gray-50 border rounded-2xl outline-none">
            <button type="submit" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold shadow-lg">Register</button>
        </form>
        <p class="text-center mt-6 text-sm">Already a member? <a href="/login" class="text-red-500 font-bold">Login</a></p>
    </div>
</body>
</html>
